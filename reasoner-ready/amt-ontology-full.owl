    <cmns-col:isMemberOf rdf:resource="http://ontology.amt.org/codes/visitor-product-categories#VisitorCodeSet"/>
    <cmns-dsg:designates rdf:resource="http://ontology.amt.org/product-categories#DiamondTooling"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#token">V039</skos:notation>
