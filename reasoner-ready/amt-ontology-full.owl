  <owl:ObjectProperty rdf:about="http://ontology.amt.org/im#mediatesAssociation">
    <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
    <rdfs:comment>Connects a Registration to the organizing Association that accepts it. Cardinality 1 on Registration -- the second mandatory Endurant participant required by gufo:Relator (the registrant is the first; the show is connected separately via im:manifestedInShow). Constrained to im:AMT in practice.</rdfs:comment>
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#Registration"/>
    <rdfs:label>mediates association</rdfs:label>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#Association"/>
  </owl:ObjectProperty>
