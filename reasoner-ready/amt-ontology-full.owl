  <owl:Class rdf:about="http://purl.org/nemo/gufo#ConcreteIndividual">
    <owl:disjointUnionOf rdf:parseType="Collection">
      <rdf:Description rdf:about="http://purl.org/nemo/gufo#Endurant"/>
      <rdf:Description rdf:about="http://purl.org/nemo/gufo#Event"/>
      <rdf:Description rdf:about="http://purl.org/nemo/gufo#Situation"/>
    </owl:disjointUnionOf>
    <rdfs:label xml:lang="en">ConcreteIndividual</rdfs:label>
    <rdfs:comment xml:lang="en">A gufo:Individual that exists in space-time. 

Concrete individuals comprise not only object-like entities (a car, a mountain, a person, a marriage, a belief), but also events (a business meeting, a soccer match) and situations (the situation in which a person weighs 80 kilograms, the situation in which a bank account is overdrawn).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Individual"/>
  </owl:Class>
