    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N796c3e212f3047a88864a043c7608b02">
        <owl:allValuesFrom rdf:resource="https://www.omg.org/spec/Commons/Collections/Arrangement"/>
