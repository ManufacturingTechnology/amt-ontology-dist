  <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isConstituentOf">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/hasConstituent">
        <cmns-av:usageNote>This property is disjoint with hasMember, and should be used in cases where the constituents of something are not considered discrete elements of whatever they are included in, such as a substance or composite.</cmns-av:usageNote>
        <rdfs:subPropertyOf rdf:resource="https://www.omg.org/spec/Commons/Collections/comprises"/>
        <skos:definition>consists of or contains</skos:definition>
        <rdfs:label>has constituent</rdfs:label>
        <owl:propertyDisjointWith rdf:resource="https://www.omg.org/spec/Commons/Collections/hasMember"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isIncludedIn">
        <skos:note>Something that is included in something else may be an independently identifiable, discrete element or may be an indistinguishable element once it is combined with the target.</skos:note>
        <owl:inverseOf rdf:resource="https://www.omg.org/spec/Commons/Collections/comprises"/>
        <rdfs:label>is included in</rdfs:label>
        <skos:definition>is contained in or an element of</skos:definition>
      </owl:ObjectProperty>
    </rdfs:subPropertyOf>
    <skos:definition>is a component of something else</skos:definition>
    <rdfs:label>is constituent of</rdfs:label>
    <owl:propertyDisjointWith>
      <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isMemberOf">
        <skos:definition>is a discrete element of</skos:definition>
        <rdfs:label>is member of</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="https://www.omg.org/spec/Commons/Collections/isIncludedIn"/>
        <owl:inverseOf rdf:resource="https://www.omg.org/spec/Commons/Collections/hasMember"/>
      </owl:ObjectProperty>
    </owl:propertyDisjointWith>
  </owl:ObjectProperty>
