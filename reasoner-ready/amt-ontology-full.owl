  <owl:ObjectProperty rdf:about="http://purl.org/nemo/gufo#isDerivedFrom">
    <rdfs:domain>
      <owl:Class rdf:nodeID="na7b06552ad6e4e3abdcbd71eccc454e5b7">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://purl.org/nemo/gufo#ComparativeRelationshipType"/>
          <rdf:Description rdf:about="http://purl.org/nemo/gufo#MaterialRelationshipType"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://purl.org/nemo/gufo#EndurantType"/>
    <rdfs:label xml:lang="en">isDerivedFrom</rdfs:label>
    <rdfs:comment xml:lang="en">Identifies a gufo:EndurantType from which the material or comparative relation can be derived. The identified gufo:EndurantType should be a subclass of gufo:Aspect, more specifically a subclass of gufo:ExtrinsicAspect in the case of a gufo:MaterialRelationshipType, and a subclass of gufo:IntrinsicAspect in the case of a gufo:ComparativeRelationshipType.

For example, "marriedWith" can be derived from "Marriage", "heavierThan" can be derived from "Weight".

See Fonseca et al. (2019).</rdfs:comment>
  </owl:ObjectProperty>
