  <owl:DatatypeProperty rdf:about="http://ontology.amt.org/im#sourceProvenance">
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#Registration"/>
    <rdfs:comment>Origin of the record. Domain im:Registration (v0.6.1, previously unset) covers any Registration sub-Kind. For VisitorRecord: "registration" (Maritz reg export) or "leads" (synthesized because badge was missing from reg export). For ExhibitorRecord: "exhibitor_raw" (Maritz exhibitor export) or "leads" (synthesized because the booth scanned in leads_raw was missing from exhibitor_raw). For AmtFacility: always "leads" (these are only discovered from scan data).</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>source provenance</rdfs:label>
  </owl:DatatypeProperty>
