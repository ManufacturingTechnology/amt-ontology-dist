  <owl:Class rdf:about="http://purl.org/nemo/gufo#PhaseMixin">
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#NonSortal"/>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#AntiRigidType"/>
    <rdfs:label xml:lang="en">PhaseMixin</rdfs:label>
    <rdfs:comment xml:lang="en">A gufo:EndurantType that is both non-sortal and anti-rigid. It is defined by intrinsic but contingent instantiation conditions. Phase mixins are relationally independent types that capture intrinsic properties shared by instances of different kinds.

For example, "LivingAnimal" may be considered a gufo:PhaseMixin as a superclass of the phases "LivingPerson" (specializing the gufo:Kind "Person") and "LivingDog" (specializing the gufo:Kind "Dog").</rdfs:comment>
    <owl:disjointWith rdf:resource="http://purl.org/nemo/gufo#RoleMixin"/>
  </owl:Class>
