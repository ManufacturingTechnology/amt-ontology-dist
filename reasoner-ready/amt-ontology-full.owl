  <owl:DatatypeProperty rdf:about="http://ontology.amt.org/im#postalCode">
    <rdfs:domain>
      <owl:Class rdf:nodeID="n234f9bcb19864ff6b7dc566604c500d7b16">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://ontology.amt.org/im#Registration"/>
          <rdf:Description rdf:about="http://ontology.amt.org/im#Membership"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:comment>Relator-anchored. Source may be numeric (US ZIP) or alphanumeric (Canadian, UK, etc.). Stored as string to preserve leading zeros. Same Visitor-vs-Membership PII split as im:city.</rdfs:comment>
    <rdfs:label>postal code</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
