  <owl:Class rdf:about="http://purl.org/nemo/gufo#Phase">
    <rdfs:comment xml:lang="en">A gufo:EndurantType that is both sortal and anti-rigid. It is defined by intrinsic but contingent instantiation conditions. Phases are relationally independent types that capturec intrinsic properties shared by instances of a given kind.

For example, "Child" may be considered a gufo:Phase as a subclass of the gufo:Kind "Person", instantiated by persons younger than 12. Another example is the type "IllPerson", which may be considered a gufo:Phase that is instantiated whenever an instance of "Disease" (a gufo:IntrinsicMode) inheres in a person.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#AntiRigidType"/>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Sortal"/>
    <owl:disjointWith rdf:resource="http://purl.org/nemo/gufo#Role"/>
    <rdfs:label xml:lang="en">Phase</rdfs:label>
  </owl:Class>
