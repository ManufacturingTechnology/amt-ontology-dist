  <owl:ObjectProperty rdf:about="http://ontology.amt.org/im#hasIndustry">
    <rdfs:comment>Industry-group classification. On VisitorRecord: the industry the visitor reported on the lead-scan questionnaire (per-attendance self-report). On Company: the union of industries declared by every VisitorRecord whose im:representsCompany is this Company -- a derived aggregate. The two are kept in sync at ingest by scripts/build_individuals.py and enforced by TestCompanyHasAllVisitorIndustries. Multi-valued by design: a company whose visitors disagree on industry is faithfully tagged with all reported industries; downstream queries can pick a winner if needed. Range scoped to ind_cs:VisitorCodeSet members.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:nodeID="n234f9bcb19864ff6b7dc566604c500d7b22">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://ontology.amt.org/im#VisitorRecord"/>
          <rdf:Description rdf:about="http://ontology.amt.org/im#Company"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has industry</rdfs:label>
    <rdfs:range rdf:resource="https://www.omg.org/spec/Commons/CodesAndCodeSets/CodeElement"/>
  </owl:ObjectProperty>
