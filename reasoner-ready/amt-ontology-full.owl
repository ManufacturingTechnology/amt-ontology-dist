  <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isDirectPartOf">
    <cmns-av:usageNote>This property is useful in cases where one is interested in the direct relationships between parts of things, for example to build a tree view.</cmns-av:usageNote>
    <skos:definition>indicates an immediate 'parent' of this part</skos:definition>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/hasDirectPart">
        <rdfs:subPropertyOf rdf:resource="https://www.omg.org/spec/Commons/Collections/hasPart"/>
        <rdfs:label>has direct part</rdfs:label>
        <cmns-av:usageNote>This property is useful in cases where one is interested in the direct relationships between parts of things, for example to build a tree view.</cmns-av:usageNote>
        <skos:definition>indicates an immediate 'child' part of something</skos:definition>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:subPropertyOf>
      <owl:TransitiveProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isPartOf">
        <owl:inverseOf rdf:resource="https://www.omg.org/spec/Commons/Collections/hasPart"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <skos:definition>relates something to another thing that it is some component or portion of, regardless of how that whole-part relationship is manifested</skos:definition>
        <skos:note>Note that 'is part of' is not a subproperty of 'isIncludedIn' in order to enable transitivity for whole-part relationships without limiting the use of cardinality constraints on inclusion and membership.</skos:note>
        <rdfs:label>is part of</rdfs:label>
        <dcterms:source>Stanford Encyclopedia of Philosophy at http://plato.stanford.edu/entries/mereology/</dcterms:source>
      </owl:TransitiveProperty>
    </rdfs:subPropertyOf>
    <rdfs:label>is direct part of</rdfs:label>
  </owl:ObjectProperty>
  <owl:AnnotationProperty rdf:about="https://www.omg.org/spec/Commons/AnnotationVocabulary/symbol">
    <rdfs:label>symbol</rdfs:label>
    <rdfs:subPropertyOf>
      <owl:AnnotationProperty rdf:about="https://www.omg.org/spec/Commons/AnnotationVocabulary/synonym">
        <cmns-av:usageNote>Note that any SPARQL or other query using entailment for the rdfs:label on any construct will return not only the rdfs:label but all labels that are specified using subproperties of rdfs:label, such as synonym.</cmns-av:usageNote>
        <cmns-av:adaptedFrom>ISO 1087 Terminology work and terminology science - Vocabulary, Second edition, 2019-09</cmns-av:adaptedFrom>
        <skos:definition>designation that can be substituted for the primary representation of something</skos:definition>
        <rdfs:label>synonym</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#altLabel"/>
      </owl:AnnotationProperty>
    </rdfs:subPropertyOf>
    <cmns-av:usageNote>Note that any SPARQL or other query using entailment for the rdfs:label on any construct will return not only the rdfs:label but all labels that are specified using subproperties of rdfs:label, such as symbol.</cmns-av:usageNote>
    <skos:definition>abbreviation that is a design or mark, or other non-alpha-numeric character(s) conventionally used to represent something, such as a currency or mathematical sign or operator</skos:definition>
  </owl:AnnotationProperty>
  <owl:AnnotationProperty rdf:about="https://www.omg.org/spec/Commons/AnnotationVocabulary/logicalDefinition">
    <rdfs:label>logical definition</rdfs:label>
    <skos:definition>definition in the form of a formal expression, such as the mathematical or logic representation, for the resource</skos:definition>
    <rdfs:subPropertyOf>
      <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/description"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
        <cmns-av:usageNote>For the purposes of OMG and other industry standards, definitions must be ISO 704 compliant.</cmns-av:usageNote>
        <skos:definition>a statement or formal explanation of the meaning of a concept</skos:definition>
        <rdfs:label>definition</rdfs:label>
      </owl:AnnotationProperty>
    </rdfs:subPropertyOf>
  </owl:AnnotationProperty>
