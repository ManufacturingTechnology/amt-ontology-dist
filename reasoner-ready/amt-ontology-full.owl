        <amtmeta:codesFor rdf:resource="http://ontology.amt.org/codes/primary-product-line#PrimaryProductLineConcept"/>
        <amtmeta:consumerFor>AMT Membership Application (member primary business segment self-selection)</amtmeta:consumerFor>
        <rdfs:label>Primary Product Line CodeSet</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <rdfs:comment>Member-side coarse segmentation answer set. 9 substantive segments cross-link (via skos:closeMatch / skos:broadMatch) to pc_ecs: Major Collection buckets in the IMTS Exhibitor pavilion taxonomy. Cross-vocabulary mapping -- PPL and pc_ecs are distinct controlled vocabularies that overlap conceptually but serve different operational purposes (membership self-identification vs show-offering classification).</rdfs:comment>
      </cmns-cds:CodeSet>
    </cmns-col:isMemberOf>
    <skos:closeMatch>
      <amtmeta:Collection rdf:about="http://ontology.amt.org/codes/exhibitor-product-categories#bucketJoiningAndForming">
