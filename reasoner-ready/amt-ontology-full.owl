  <owl:ObjectProperty rdf:about="http://ontology.amt.org/im#mediatesAssociation">
    <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
    <rdfs:comment>Connects a Registration OR Membership to the organizing/owning Association that accepts it. For Registration this is the show organizer (im:AMT for IMTS); for Membership this is the association the member belongs to (im:AMT). Cardinality 1 on each Relator subject. Constrained to im:AMT in practice.</rdfs:comment>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#Association"/>
    <rdfs:label>mediates association</rdfs:label>
    <rdfs:domain>
      <owl:Class rdf:nodeID="n234f9bcb19864ff6b7dc566604c500d7b4">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://ontology.amt.org/im#Registration"/>
          <rdf:Description rdf:about="http://ontology.amt.org/im#Membership"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
  </owl:ObjectProperty>
