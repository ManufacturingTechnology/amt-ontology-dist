        <owl:onProperty rdf:resource="http://ontology.amt.org/im#mediatesMember"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Relator"/>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="n234f9bcb19864ff6b7dc566604c500d7b56">
        <owl:onProperty rdf:resource="http://ontology.amt.org/im#hasPrimaryProductLine"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
