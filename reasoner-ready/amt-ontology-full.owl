  <owl:Class rdf:about="http://purl.org/nemo/gufo#Quality">
    <rdfs:comment xml:lang="en">A gufo:IntrinsicAspect that is measurable by some value spaces. A quality may be used to compare individuals, on the basis of the value it takes in a certain quality space (for instance, a position within the RGB spectrum).

Examples include the weight of a person, the name of organization, the color of a car, and the duration of a concert.</rdfs:comment>
    <rdfs:label xml:lang="en">Quality</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#IntrinsicAspect"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://ontology.amt.org/im#manifestedInShow">
    <rdfs:label>manifested in show</rdfs:label>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#IMTS"/>
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="http://purl.org/nemo/gufo#manifestedIn">
        <rdfs:comment xml:lang="en">Identifies a gufo:Event in which the gufo:Aspect is manifested.

For example, the passing of an electrical current in a conductor is an event that encompasses the manifestation of an aspect inhering in a copper wire (the wire's  electrical conductivity).</rdfs:comment>
        <rdfs:domain rdf:resource="http://purl.org/nemo/gufo#Aspect"/>
        <rdfs:label xml:lang="en">manifestedIn</rdfs:label>
        <rdfs:range rdf:resource="http://purl.org/nemo/gufo#Event"/>
      </owl:ObjectProperty>
    </rdfs:subPropertyOf>
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#Registration"/>
  </owl:ObjectProperty>
