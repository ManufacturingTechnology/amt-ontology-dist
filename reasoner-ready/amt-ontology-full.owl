  <owl:Class rdf:about="http://purl.org/nemo/gufo#NonRigidType">
    <owl:disjointUnionOf rdf:parseType="Collection">
      <rdf:Description rdf:about="http://purl.org/nemo/gufo#AntiRigidType"/>
      <rdf:Description rdf:about="http://purl.org/nemo/gufo#SemiRigidType"/>
    </owl:disjointUnionOf>
    <rdfs:comment xml:lang="en">A gufo:EndurantType that does not apply necessarily to at least one of its instances (see Guizzardi, 2005, chapter 4).

Examples include anti-rigid types, such as the role "Student" and the phase "Child", and semi-rigid types, such as the mixin "MusicalArtist" (which necessarily characterizes bands, but contingently characterizes people) and the mixin "FemaleAnimal" (which is necessarily characterizes female dogs, but contigently characterizes clownfish).</rdfs:comment>
    <owl:disjointWith rdf:resource="http://purl.org/nemo/gufo#RigidType"/>
    <rdfs:label xml:lang="en">NonRigidType</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#EndurantType"/>
  </owl:Class>
