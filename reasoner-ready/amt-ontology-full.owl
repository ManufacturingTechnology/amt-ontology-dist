  <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel">
    <rdfs:label>preferred label</rdfs:label>
    <skos:definition>the preferred lexical label for a resource, in a given language</skos:definition>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
    <skos:note>skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</skos:note>
    <skos:note>A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag.</skos:note>
    <skos:note>The range of skos:prefLabel is the class of RDF plain literals.</skos:note>
  </owl:AnnotationProperty>
