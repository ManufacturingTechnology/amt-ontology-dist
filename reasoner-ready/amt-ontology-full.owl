  <owl:ObjectProperty rdf:about="http://ontology.amt.org/im#mediatesExhibitor">
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#ExhibitorRecord"/>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#Exhibitor"/>
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="http://purl.org/nemo/gufo#mediates">
        <rdfs:range rdf:resource="http://purl.org/nemo/gufo#Endurant"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:label xml:lang="en">mediates</rdfs:label>
        <rdfs:domain rdf:resource="http://purl.org/nemo/gufo#Relator"/>
        <rdfs:comment xml:lang="en">Identifies the endurants mediated by a gufo:Relator.

For example, John and Mary's marriage mediates John and Mary.</rdfs:comment>
      </owl:ObjectProperty>
    </rdfs:subPropertyOf>
    <rdfs:label>mediates exhibitor</rdfs:label>
  </owl:ObjectProperty>
