  <owl:DatatypeProperty rdf:about="https://www.omg.org/spec/Commons/Designators/hasTag">
    <rdfs:label>has tag</rdfs:label>
    <skos:note>Text-valued tags can be useful for controlled vocabulary encoding or transformation, such as those used to produce IETF compliant language tags in XML.</skos:note>
    <rdfs:subPropertyOf>
      <owl:DatatypeProperty rdf:about="https://www.omg.org/spec/Commons/TextDatatype/hasTextValue">
        <skos:note>Note that although the intended range for this property is Text, we have left the range undefined so that it can be used with tools that do not support rdf:langString.</skos:note>
        <rdfs:label>has text value</rdfs:label>
        <skos:definition>provides a string value for something, with or without a language tag</skos:definition>
      </owl:DatatypeProperty>
    </rdfs:subPropertyOf>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <skos:definition>associates unique combination of alphanumeric characters corresponding to a designator for something</skos:definition>
  </owl:DatatypeProperty>
