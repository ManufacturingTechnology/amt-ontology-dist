  <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel">
    <skos:definition>an alternative lexical label for a resource</skos:definition>
    <skos:note>skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</skos:note>
    <skos:note>The range of skos:altLabel is the class of RDF plain literals.</skos:note>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    <skos:example>Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel).</skos:example>
    <rdfs:label>alternative label</rdfs:label>
  </owl:AnnotationProperty>
