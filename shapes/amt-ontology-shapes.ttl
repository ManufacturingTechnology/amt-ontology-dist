@prefix sh:        <http://www.w3.org/ns/shacl#> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix amtmeta:   <http://ontology.amt.org/meta#> .
@prefix amt-codes: <http://ontology.amt.org/shapes/codes#> .
@prefix imShape:   <http://ontology.amt.org/shapes/im#> .
@prefix im:        <http://ontology.amt.org/im#> .
@prefix pc_vcs:    <http://ontology.amt.org/codes/visitor-product-categories#> .
@prefix pc_ecs:    <http://ontology.amt.org/codes/exhibitor-product-categories#> .
@prefix cmns-cds:  <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col:  <https://www.omg.org/spec/Commons/Collections/> .
@prefix cmns-dsg:  <https://www.omg.org/spec/Commons/Designators/> .
@prefix lead_pc_cs: <http://ontology.amt.org/codes/lead-product-interest#> .
@prefix ex_raw_pc_cs: <http://ontology.amt.org/codes/exhibitor-raw-product-categories#> .

##
## SHACL shapes for AMT CodeSet vocabularies.
##
## Loaded by tests/test_shacl_shapes.py against the union of any
## CodeSet vocabulary (e.g. ontology/codes/ind_codeset.ttl) and the
## taxonomy it provides codes for (e.g. ontology/ind.ttl), so that
## cmns-dsg:designates targets resolve to declared individuals.
##
## Shapes here are independent of the legacy Collection / amtmeta:groups
## machinery in view-shapes.ttl.
##

##
## Within a single cmns-cds:CodeSet, no two CodeElements may share a
## skos:notation. (The CodeSet itself is the uniqueness scope -- demoId
## is allowed to vary across elements and is intentionally NOT part of
## the key. Cross-CodeSet collisions are permitted: different consumers
## may legitimately reuse the same notation string.)
##
amt-codes:NotationUniqueInCodeSet
    a sh:NodeShape ;
    rdfs:label     "Notation must be unique within a CodeSet" ;
    sh:targetClass cmns-cds:CodeSet ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Two cmns-cds:CodeElement instances in this CodeSet share the same skos:notation -- the CodeSet is meant to be the uniqueness scope for the form's Answer ID." ;
        sh:prefixes [
            sh:declare [ sh:prefix "cmns-col" ; sh:namespace "https://www.omg.org/spec/Commons/Collections/"^^xsd:anyURI ] ;
            sh:declare [ sh:prefix "skos"     ; sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ] ;
        ] ;
        sh:select """
            SELECT $this ?notation WHERE {
                ?e1 cmns-col:isMemberOf $this ;
                    skos:notation       ?notation .
                ?e2 cmns-col:isMemberOf $this ;
                    skos:notation       ?notation .
                FILTER (?e1 != ?e2)
            }
        """ ;
    ] .


##
## Every cmns-cds:CodeElement must carry the two always-required
## load-bearing properties:
##
##   * exactly one cmns-col:isMemberOf pointing at a cmns-cds:CodeSet
##     (the CodeSet that scopes this code's notation),
##   * exactly one skos:notation typed xsd:token
##     (the form-side Answer ID).
##
## cmns-dsg:designates is required conditionally -- enforced by the
## DesignatesRequiredForNonSentinelShape below, which exempts
## amtmeta:SentinelCodeElement instances (e.g. "No Response", which
## records the absence of an answer rather than a canonical concept).
##
amt-codes:CodeElementBasicsShape
    a sh:NodeShape ;
    rdfs:label     "CodeElement structural basics" ;
    sh:targetClass cmns-cds:CodeElement ;

    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:class    cmns-cds:CodeSet ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Every cmns-cds:CodeElement must be cmns-col:isMemberOf exactly one cmns-cds:CodeSet." ;
    ] ;

    sh:property [
        sh:path     skos:notation ;
        sh:datatype xsd:token ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Every cmns-cds:CodeElement must have exactly one xsd:token-typed skos:notation." ;
    ] .


##
## Every cmns-cds:CodeElement must be display-label-resolvable. That
## resolves in one of two ways:
##
##   1. via cmns-dsg:designates to a target carrying skos:prefLabel
##      (the Industry / Visitor / Exhibitor PC pattern -- CodeElement
##      points at a canonical Classifier or pc class which holds the
##      label),
##   2. via skos:prefLabel asserted directly on the CodeElement
##      (the IMTS RegClass / JobFn / AcqRole / EmpCount pattern --
##      controlled vocabularies with no underlying Classifier layer).
##
## This shape fails a CodeElement that has neither. Sentinel
## CodeElements (amtmeta:SentinelCodeElement) are exempt: they carry
## their own skos:prefLabel (so they actually satisfy form 2 above) and
## are not required to designate (the sh:hasValue requirement on
## designates is dropped by SentinelNoDesignatesShape).
##
## 1..* (no maxCount) on designates allows a legacy "lumped" answer
## such as "Aerospace & Defense" to designate both ind:Aerospace and
## ind:Defense.
##
amt-codes:DesignatesRequiredForNonSentinelShape
    a sh:NodeShape ;
    rdfs:label     "Non-sentinel CodeElement must designate" ;
    sh:targetClass cmns-cds:CodeElement ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Non-sentinel cmns-cds:CodeElement must have at least one cmns-dsg:designates IRI." ;
        sh:prefixes [
            sh:declare [ sh:prefix "amtmeta"  ; sh:namespace "http://ontology.amt.org/meta#"^^xsd:anyURI ] ;
            sh:declare [ sh:prefix "cmns-dsg" ; sh:namespace "https://www.omg.org/spec/Commons/Designators/"^^xsd:anyURI ] ;
            sh:declare [ sh:prefix "skos"     ; sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ] ;
        ] ;
        sh:select """
            SELECT $this WHERE {
                FILTER NOT EXISTS { $this a amtmeta:SentinelCodeElement }
                FILTER NOT EXISTS { $this cmns-dsg:designates ?target }
                FILTER NOT EXISTS { $this skos:prefLabel ?label }
            }
        """ ;
    ] .


##
## Sentinel CodeElements must NOT carry cmns-dsg:designates targets --
## a sentinel that points at a canonical concept contradicts its own
## purpose (the whole point of a sentinel is to record absence of a
## designation).
##
amt-codes:SentinelNoCanonicalDesignatesShape
    a sh:NodeShape ;
    rdfs:label     "Sentinel CodeElement must not designate a canonical concept" ;
    sh:targetClass amtmeta:SentinelCodeElement ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "amtmeta:SentinelCodeElement may only designate another SentinelCodeElement (e.g. the parallel-'Other'-across-codesets case); designating a canonical concept defeats the sentinel's purpose." ;
        sh:prefixes [
            sh:declare [ sh:prefix "amtmeta"  ; sh:namespace "http://ontology.amt.org/meta#"^^xsd:anyURI ] ;
            sh:declare [ sh:prefix "cmns-dsg" ; sh:namespace "https://www.omg.org/spec/Commons/Designators/"^^xsd:anyURI ] ;
        ] ;
        sh:select """
            SELECT $this ?target WHERE {
                $this cmns-dsg:designates ?target .
                FILTER NOT EXISTS { ?target a amtmeta:SentinelCodeElement }
            }
        """ ;
    ] .


##
## Every cmns-cds:CodeSet must carry exactly one amtmeta:codesFor target
## (the canonical taxonomy individual the codes designate).
##
amt-codes:CodeSetCodesForShape
    a sh:NodeShape ;
    rdfs:label     "CodeSet must declare codesFor" ;
    sh:targetClass cmns-cds:CodeSet ;
    sh:property [
        sh:path     amtmeta:codesFor ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Every cmns-cds:CodeSet must carry exactly one amtmeta:codesFor pointing at the canonical taxonomy individual the codes designate." ;
    ] .


##
## IM-side validation shapes.
##
## VisitorRecord.im:hasInterest values must be CodeElements in
## pc_vcs:VisitorCodeSet; ExhibitorRecord.im:hasProductCategory values
## must be CodeElements in pc_ecs:ExhibitorCodeSet. This is the bucket-
## membership half of the constraint inherited from the retired
## visitor_view:VisitorInterestShape / exhibitor_view:ExhibitorOfferingShape
## -- one hop shorter than before (the materialized im:Interest /
## im:ProductCategory aspect Kinds were dropped in im.ttl v0.3.0).
##
## Catalog-grade (amtmeta:CatalogValueShape: target carries skos:prefLabel)
## should be applied to the designated pc class one hop further via
## cmns-dsg:designates. That second half is not encoded here because the
## existing per-CodeElement basics (DesignatesRequiredForNonSentinelShape)
## already guarantees non-sentinel codes designate at least one pc class;
## and that pc class is itself in pc.ttl which carries skos:prefLabel on
## every entity that should be selectable. Sentinel CodeElements
## (Other / NoResponse) carry skos:prefLabel locally and are valid form
## answers despite having no designation.
##

imShape:VisitorInterestShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Interest Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path im:hasInterest ;
        sh:node imShape:VisitorCodeSetMember ;
        sh:message "Every im:hasInterest target on an im:VisitorRecord must be a cmns-cds:CodeElement that is cmns-col:isMemberOf pc_vcs:VisitorCodeSet." ;
    ] .

imShape:VisitorCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue pc_vcs:VisitorCodeSet ;
        sh:minCount 1 ;
    ] .

imShape:ExhibitorOfferingShape
    a sh:NodeShape ;
    rdfs:label     "Exhibitor Product Category Constraint" ;
    sh:targetClass im:ExhibitorRecord ;
    sh:property [
        sh:path     im:hasProductCategory ;
        sh:node     imShape:ExhibitorRawCodeSetMember ;
        sh:message  "Every im:hasProductCategory target on an im:ExhibitorRecord must be a cmns-cds:CodeElement isMemberOf ex_raw_pc_cs:ExhibitorRawCodeSet (the 2024 IMTS catalog vocabulary). The post-2024 harmonized pc_ecs vocabulary is reached via cmns-dsg:designates on each ex_raw_pc_cs CodeElement." ;
    ] .

imShape:ExhibitorRawCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue ex_raw_pc_cs:ExhibitorRawCodeSet ;
        sh:minCount 1 ;
    ] .


##
## v0.4.0 additions -- per-property scoping for the four new codesets
## introduced for visitor-ingestion data: im:registrationClass,
## im:hasIndustry, im:jobFunction, im:acquisitionRole,
## im:plantEmployeeCount. Each property's target must be a CodeElement
## isMemberOf the right consumer's root CodeSet.
##

imShape:VisitorRegistrationClassShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Registration Class Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:registrationClass ;
        sh:node     imShape:IMTSRegClassCodeSetMember ;
        sh:maxCount 1 ;
        sh:message  "im:registrationClass target on a VisitorRecord must be a CodeElement isMemberOf imts_rc_cs:IMTSRegistrationCategoryCodeSet." ;
    ] .

imShape:IMTSRegClassCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/codes/imts-registration-category#IMTSRegistrationCategoryCodeSet> ;
        sh:minCount 1 ;
    ] .


imShape:VisitorIndustryShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Industry Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:hasIndustry ;
        sh:node     imShape:IndustryCodeSetMember ;
        sh:maxCount 1 ;
        sh:message  "im:hasIndustry target on a VisitorRecord must be a CodeElement isMemberOf ind_cs:VisitorCodeSet." ;
    ] .

imShape:IndustryCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/codes/industries#VisitorCodeSet> ;
        sh:minCount 1 ;
    ] .


imShape:VisitorJobFunctionShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Job Function Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:jobFunction ;
        sh:node     imShape:JobFunctionCodeSetMember ;
        sh:maxCount 1 ;
        sh:message  "im:jobFunction target on a VisitorRecord must be a CodeElement isMemberOf jobfn_cs:JobFunctionCodeSet." ;
    ] .

imShape:JobFunctionCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/codes/job-function#JobFunctionCodeSet> ;
        sh:minCount 1 ;
    ] .


imShape:VisitorAcquisitionRoleShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Acquisition Role Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:acquisitionRole ;
        sh:node     imShape:AcquisitionRoleCodeSetMember ;
        sh:maxCount 1 ;
        sh:message  "im:acquisitionRole target on a VisitorRecord must be a CodeElement isMemberOf acqrole_cs:AcquisitionRoleCodeSet." ;
    ] .

imShape:AcquisitionRoleCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/codes/acquisition-role#AcquisitionRoleCodeSet> ;
        sh:minCount 1 ;
    ] .


imShape:VisitorPlantEmployeeCountShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Plant Employee Count Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:plantEmployeeCount ;
        sh:node     imShape:PlantEmployeeCountCodeSetMember ;
        sh:maxCount 1 ;
        sh:message  "im:plantEmployeeCount target on a VisitorRecord must be a CodeElement isMemberOf empcount_cs:PlantEmployeeCountCodeSet." ;
    ] .

imShape:PlantEmployeeCountCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/codes/plant-employee-count#PlantEmployeeCountCodeSet> ;
        sh:minCount 1 ;
    ] .


##
## v0.5.0 additions -- JIMTOF exhibitor scope. im:hasProductCategory on a
## JIMTOF exhibitor must come from pc_jimtof_cs:JimtofCodeSet, and
## im:servesIndustry from ind_jimtof_cs:JimtofIndustryCodeSet. (im: side
## of these properties has no domain so they can be reused, hence per-
## targetClass shapes here.)
##

imShape:JimtofExhibitorProductCategoryShape
    a sh:NodeShape ;
    rdfs:label     "JIMTOF Exhibitor Product Category Constraint" ;
    sh:targetClass <http://ontology.amt.org/external/codes/jimtof-product-categories#Exhibitor> ;
    sh:property [
        sh:path     im:hasProductCategory ;
        sh:node     imShape:JimtofPcCodeSetMember ;
        sh:message  "im:hasProductCategory target on a pc_jimtof_cs:Exhibitor must be a CodeElement isMemberOf pc_jimtof_cs:JimtofCodeSet." ;
    ] .

imShape:JimtofPcCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/external/codes/jimtof-product-categories#JimtofCodeSet> ;
        sh:minCount 1 ;
    ] .

imShape:JimtofExhibitorServesIndustryShape
    a sh:NodeShape ;
    rdfs:label     "JIMTOF Exhibitor Serves Industry Constraint" ;
    sh:targetClass <http://ontology.amt.org/external/codes/jimtof-product-categories#Exhibitor> ;
    sh:property [
        sh:path     im:servesIndustry ;
        sh:node     imShape:JimtofIndustryCodeSetMember ;
        sh:message  "im:servesIndustry target on a pc_jimtof_cs:Exhibitor must be a CodeElement isMemberOf ind_jimtof_cs:JimtofIndustryCodeSet." ;
    ] .

imShape:JimtofIndustryCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue <http://ontology.amt.org/external/codes/jimtof-industries#JimtofIndustryCodeSet> ;
        sh:minCount 1 ;
    ] .


##
## v0.5.0 -- lead-scan form product-interest scope. Distinct vocabulary
## from pc_vcs (registration-form interest); see lead_pc_codeset.ttl.
##


imShape:VisitorLeadFormInterestShape
    a sh:NodeShape ;
    rdfs:label     "Visitor Lead-Form Interest Constraint" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:hasLeadFormInterest ;
        sh:node     imShape:LeadFormInterestCodeSetMember ;
        sh:message  "im:hasLeadFormInterest target on a VisitorRecord must be a CodeElement isMemberOf lead_pc_cs:LeadProductInterestCodeSet." ;
    ] .

imShape:LeadFormInterestCodeSetMember
    a sh:NodeShape ;
    sh:property [
        sh:path     cmns-col:isMemberOf ;
        sh:hasValue lead_pc_cs:LeadProductInterestCodeSet ;
        sh:minCount 1 ;
    ] .


##
## amtmeta:CatalogValueShape -- canonical "is this a usable catalog
## value?" constraint. Marker class declared in amtmeta.ttl; the SHACL
## NodeShape definition lives here so we don't pull the http://www.w3.org/ns/shacl
## vocabulary into the merged amt-ontology.owl.
##

amtmeta:CatalogValueShape
    a sh:NodeShape ;
    rdfs:label "Catalog Value Constraint" ;
    sh:property [
        sh:path     skos:prefLabel ;
        sh:minCount 1 ;
        sh:message  "Value is abstract (lacks skos:prefLabel) and cannot be used as a catalog value." ;
    ] .


##
## v0.5.2 -- closed-world exact-cardinality invariants, aligned to the
## actual data emitted by scripts/build_individuals.py.
##
## The OWL side carries owl:minCardinality 1 (so reasoners can derive
## the lower bound without backtracking on gUFO Relator's >=2 mediates
## restriction); these SHACL shapes restore the "exactly one" check
## per instance for the *populated* fields. Shapes for UFO-pure
## properties (im:mediatesExhibitor / im:mediatesAssociation /
## im:manifestedInShow / im:Organizing) are intentionally omitted --
## the build script does not currently emit them; they remain
## aspirational OWL constraints only.
##

imShape:CompanyLabelShape
    a sh:NodeShape ;
    rdfs:label "Company must carry exactly one rdfs:label" ;
    sh:targetClass im:Company ;
    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:Company must have exactly one rdfs:label (the canonical company name; variants live as skos:altLabel)." ;
    ] .

imShape:VisitorRecordFieldsShape
    a sh:NodeShape ;
    rdfs:label "VisitorRecord core fields cardinality" ;
    sh:targetClass im:VisitorRecord ;
    sh:property [
        sh:path     im:badge ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:VisitorRecord must have exactly one im:badge." ;
    ] ;
    sh:property [
        sh:path     im:uuid ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:VisitorRecord must have exactly one im:uuid." ;
    ] ;
    sh:property [
        sh:path     im:registeredForShow ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:VisitorRecord must im:registeredForShow exactly one show." ;
    ] .

imShape:ExhibitorRecordFieldsShape
    a sh:NodeShape ;
    rdfs:label "ExhibitorRecord core fields cardinality" ;
    sh:targetClass im:ExhibitorRecord ;
    sh:property [
        sh:path     im:booth ;
        sh:minCount 1 ;
        sh:message  "Every im:ExhibitorRecord must have at least one im:booth (an exhibitor may occupy multiple booths)." ;
    ] ;
    sh:property [
        sh:path     im:registeredForShow ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:ExhibitorRecord must im:registeredForShow exactly one show." ;
    ] ;
    sh:property [
        sh:path     im:representsCompany ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:ExhibitorRecord must im:representsCompany exactly one im:Company." ;
    ] .

imShape:LeadFieldsShape
    a sh:NodeShape ;
    rdfs:label "Lead core fields cardinality" ;
    sh:targetClass im:Lead ;
    sh:property [
        sh:path     im:leadOfVisitor ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message  "Every im:Lead must have exactly one im:leadOfVisitor." ;
    ] ;
    sh:property [
        sh:path     im:leadOfExhibitor ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:or (
            [ sh:class im:ExhibitorRecord ]
            [ sh:class im:AmtFacility ]
        ) ;
        sh:message  "Every im:Lead must have exactly one im:leadOfExhibitor, pointing at an im:ExhibitorRecord or im:AmtFacility." ;
    ] .
