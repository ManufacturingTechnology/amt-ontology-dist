  <rdf:Description rdf:about="http://ontology.amt.org/meta#promptsFreeText">
    <rdfs:label>prompts free text</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment>Asserted on a cmns-cds:CodeElement when the originating form captures a free-text string alongside selection of this code (e.g. "Other (Please specify)"). The string itself is form / storage runtime data and is NOT stored in the ontology -- this flag only records the UI affordance so downstream tools know to render and capture the prompt. Implied false when absent.</rdfs:comment>
  </rdf:Description>
