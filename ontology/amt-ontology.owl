  <rdf:Description rdf:about="http://ontology.amt.org/meta#CodeSetVocabulary">
    <rdfs:label>Code Set Vocabulary</rdfs:label>
    <rdfs:comment>An ontology file that packages one or more cmns-cds:CodeSet individuals together with their CodeElements. Used to bind a department / form / downstream system's native identifier scheme (e.g. Visitor Registration Answer IDs) to canonical concepts in the AMT taxonomies. See amtmeta:codesFor (which taxonomy the codes designate) and amtmeta:consumerFor (which downstream system consumes the codes).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://ontology.amt.org/meta#Vocabulary"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
