  <rdf:Description rdf:about="http://ontology.amt.org/im#sourceProvenance">
    <rdfs:comment>Origin of the record. Domain deliberately unset so any Registration subKind can use it. For VisitorRecord: "registration" (Maritz reg export) or "leads" (synthesized because badge was missing from reg export). For ExhibitorRecord: "exhibitor_raw" (Maritz exhibitor export) or "leads" (synthesized because the booth scanned in leads_raw was missing from exhibitor_raw). For AmtFacility: always "leads" (these are only discovered from scan data).</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>source provenance</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
