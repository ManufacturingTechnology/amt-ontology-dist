  <rdf:Description rdf:about="http://ontology.amt.org/im#mediatesAssociation">
    <rdfs:comment>Connects a Registration to the organizing Association that accepts it. Cardinality 1 on Registration. This is the second mandatory Endurant participant required by gufo:Relator (the registrant is the first; the show is an Event and is connected separately via im:manifestedInShow). Combined with im:organizes' singleton domain { im:AMT } (D23), this value is constrained to im:AMT in practice.</rdfs:comment>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#Association"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#Registration"/>
    <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
    <rdfs:label>mediates association</rdfs:label>
  </rdf:Description>
