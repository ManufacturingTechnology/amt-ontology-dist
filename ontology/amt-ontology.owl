  <rdf:Description rdf:about="http://ontology.amt.org/im#representsCompany">
    <rdfs:range rdf:resource="http://ontology.amt.org/im#Company"/>
    <rdfs:label>represents company</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Links a VisitorRecord or ExhibitorRecord to the corporate entity they belong to. Domain deliberately unset — used by both record types and (forward-compat) JIMTOF Exhibitor too. Target Company IRI is hash-derived from the normalized company name (im:company_&lt;sha1[:12]&gt;) so identical companies across IMTS visitors / IMTS exhibitors collapse to the same Company entity.</rdfs:comment>
  </rdf:Description>
