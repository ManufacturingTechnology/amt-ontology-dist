@prefix im:       <http://ontology.amt.org/im#> .
@prefix amtmeta:  <http://ontology.amt.org/meta#> .
@prefix ind:      <http://ontology.amt.org/industries#> .
@prefix gufo:     <http://purl.org/nemo/gufo#> .
@prefix cmns-cds: <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .

<http://ontology.amt.org/im>
    a owl:Ontology, amtmeta:InformationModel ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://ontology.amt.org/product-categories>,
                <http://ontology.amt.org/industries>,
                <http://purl.org/nemo/gufo> ;

    dcterms:title    "AMT/IMTS Information Model" ;
    owl:versionInfo  "0.6.1" ;
    owl:versionIRI   <http://ontology.amt.org/im/0.6.1> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Chris Downs" ;
    amtmeta:governedBy          "Allison", "Ryan", "Downs" ;
    amtmeta:consumedBy          "Kristin", "Mark K", "Jess", "Allison",
                                "Downs", "Alka", "Kalesh" ;
    amtmeta:technicalSteward    "Shaurabh" ;

    amtmeta:relatedProduct
        "IMTS (visitor reg and exhibitor categories/showrooms)",
        "Passport",
        "Media Sponsorships (media kit)" ;

    amtmeta:relatedSystem
        "Maritz",
        "Hubspot",
        "Data warehouse",
        "Passport",
        "Exhibitor Space Application (linked at major category)" ;

    amtmeta:nextReviewDate      "2026-06-01"^^xsd:date ;
    amtmeta:nextReviewNote      "Need to discuss for Space Application." ;

    amtmeta:relatedDocumentation <https://amtonline.sharepoint.com/sites/governance/Shared%20Documents/Taxonomy%20Change%20Process.docx> ;

    amtmeta:releaseDate     "2026-06-29"^^xsd:date ;
    amtmeta:scopeSummary    "AMT Information Model: registration / lead / organizing / membership relator patterns plus the per-record ingestion-data property surface. Cross-ontology classification of Industry / Interest / Product Category / MT Role / Primary Product Line is mediated through OMG Commons CodeSets in ontology/codes/. Trade-show class hierarchy (im:TradeShow) supports both IMTS and external shows. v0.6.0 added im:Member (Role) + im:Membership (Relator, sibling of im:Registration) for AMT member-application data. v0.6.1 refines the address/URL surface: every per-record snapshot field (streetAddress, city, stateProvince, postalCode, country, companyURL) attaches to a Relator (Registration or Membership), never to a substantial entity (Company / Person) directly. Company stays identity-only and is reached via mediatesMember from its current Membership." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.6.1" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.6.1> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.6.1> ;

    amtmeta:useCase
        "Encodes registration data captured at IMTS shows",
        "Backbone for visitor/exhibitor matching queries",
        "Bridge between pc: and ind: taxonomies",
        "Captures post-show leads data via Lead relator",
        "Encodes AMT member-application data via Member role + Membership relator" .

#-------------------------------------------------------------------------------
# Kinds — substantial entities
#-------------------------------------------------------------------------------

im:Organization a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Organization" .

im:Association a owl:Class, gufo:Kind ;
    rdfs:subClassOf im:Organization ;
    rdfs:label "Association" .

im:Person a owl:Class, gufo:Kind ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Person" .

im:Company a owl:Class, gufo:Kind ;
    rdfs:subClassOf im:Organization ;
    rdfs:label "Company" .

im:Department a owl:Class, gufo:Kind ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Department" .

im:ExhibitionDepartment a owl:Class, gufo:SubKind ;
    rdfs:subClassOf im:Department ;
    rdfs:label "Exhibition Department" .

#-------------------------------------------------------------------------------
# Trade shows
#-------------------------------------------------------------------------------
# im:TradeShow is the superclass for any trade-show event. AMT-managed IMTS
# is one specialisation; external shows (e.g. pc_jimtof_cs:JIMTOF) plug in
# as further subclasses without modifying this file.

im:TradeShow a owl:Class, gufo:EventType ;
    rdfs:subClassOf gufo:Event ;
    rdfs:label "Trade Show" .

im:IMTS a owl:Class, gufo:EventType ;
    rdfs:subClassOf im:TradeShow ;
    rdfs:label "IMTS Show" .

#-------------------------------------------------------------------------------
# Roles — anti-rigid sortals played by Kinds
#-------------------------------------------------------------------------------

im:Visitor a owl:Class, gufo:Role ;
    rdfs:subClassOf im:Person ;
    rdfs:label "Visitor" .

im:Exhibitor a owl:Class, gufo:Role ;
    rdfs:subClassOf im:Company ;
    rdfs:label "Exhibitor" .

im:BoothStaff a owl:Class, gufo:Role ;
    rdfs:subClassOf im:Visitor ;
    rdfs:label "Booth Staff" .

im:Member a owl:Class, gufo:Role ;
    rdfs:subClassOf im:Company ;
    rdfs:label "AMT Member" ;
    rdfs:comment "A Company in its capacity as an AMT member. Anti-rigid Role: the same Company may cease to be a member without losing its Company identity. Distinct from im:Exhibitor (per-show role played for IMTS) -- Member is the org-level long-running role with AMT itself, scoped to the bylaw-defined member categories in mtrole_cs and self-declared market segment in ppl_cs. The role's data lives on im:Membership (the Relator that mediates Member and im:AMT); the Role itself is just the role-typing on the Company." .

#-------------------------------------------------------------------------------
# Cross-ontology classifiers
#-------------------------------------------------------------------------------
# Three classification axes wire IM entities to canonical taxonomies:
#
#   * Industry        — Company cmns-cls:isClassifiedBy ind:<Classifier>
#   * Interest        — VisitorRecord im:hasInterest pc_vcs:code<X>
#   * ProductCategory — ExhibitorRecord im:hasProductCategory pc_ecs:code<X>
#
# Membership scope (each value must come from the right CodeSet) is
# enforced by shapes in shapes/codeset-shapes.ttl. The cmns-cls:Classifier
# Aspect is unrelated to gufo:Aspect (Mode/Quality/Relator) -- the name
# overlap is coincidental.

#-------------------------------------------------------------------------------
# Relational aspect Kinds — registrations, leads, organizing
#-------------------------------------------------------------------------------
# All three sit under gufo:RelationalAspect. Registration is a Relator
# (symmetric mediation across registrant + organizing Association). Lead and
# Organizing are ExtrinsicModes (asymmetric — one privileged bearer,
# one external relatum).

im:Registration a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:Relator ;
    rdfs:label "Registration" .

im:VisitorRecord a owl:Class, gufo:Kind ;
    rdfs:subClassOf im:Registration ;
    rdfs:label "Visitor Record" .

im:ExhibitorRecord a owl:Class, gufo:Kind ;
    rdfs:subClassOf im:Registration ;
    rdfs:label "Exhibitor Record" .

im:AmtFacility a owl:Class, gufo:Kind ;
    rdfs:subClassOf im:Registration ;
    rdfs:label "AMT Facility Record" ;
    rdfs:comment "Per-show record for an AMT-operated venue space that has a booth scanner but is not a commercial exhibitor -- e.g. AMT Member Lounge (S103), International Lounge (N226). Sibling Kind of im:ExhibitorRecord under im:Registration. Carries im:representsCompany (typically AMT itself), im:booth, im:registeredForShow, and is the target of im:leadOfExhibitor when a badge is scanned at an AMT facility. Does NOT carry im:hasProductCategory or im:servesIndustry." .

im:Membership a owl:Class, gufo:Kind ;
    rdfs:subClassOf gufo:Relator ;
    rdfs:label "Membership" ;
    rdfs:comment "Long-running AMT membership relationship. Sibling of im:Registration under gufo:Relator (not a sub-Kind -- Registration is per-show, Membership is org-level). Mediates one im:Member (the company) and one im:Association (im:AMT in practice). One Membership instance per Company; renewals extend the same instance rather than minting a new one. Carries the org-level membership-application attributes: im:hasMTRole (bylaw-defined member type) and im:hasPrimaryProductLine (coarse business segment). Lifecycle fields like memberSinceDate / dues / memberClass are not modeled here yet -- they will land when AMT supplies a Salesforce export carrying those columns (see docs/decisions/im.md)." .

im:Lead a owl:Class, gufo:Kind ;
    rdfs:subClassOf gufo:ExtrinsicMode ;
    rdfs:label "Lead" .

im:Organizing a owl:Class, gufo:Kind ;
    rdfs:subClassOf gufo:ExtrinsicMode ;
    rdfs:label "Organizing" .

#-------------------------------------------------------------------------------
# Named individuals
#-------------------------------------------------------------------------------

im:AMT a owl:NamedIndividual, im:Association ;
    rdfs:label "AMT — The Association For Manufacturing Technology" .

im:AMTExhibitionDepartment a owl:NamedIndividual, im:ExhibitionDepartment ;
    gufo:isComponentOf im:AMT ;
    rdfs:label "AMT Exhibition Department" .

#-------------------------------------------------------------------------------
# Datatype properties
#-------------------------------------------------------------------------------

im:uuid a owl:DatatypeProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  xsd:string ;
    rdfs:label  "uuid" .

im:registrationDate a owl:DatatypeProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  xsd:date ;
    rdfs:label  "registration date" .

im:badge a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "badge" ;
    rdfs:comment "Badge identifier. Stored as xsd:string because badge IDs are formally opaque -- the IMTS 2024 set happens to be all numeric, but new shows or future Maritz allocations may include alphanumeric prefixes, and visitor_raw treats them as strings throughout." .

im:booth a owl:DatatypeProperty ;
    rdfs:domain im:ExhibitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "booth" ;
    rdfs:comment "Booth number assigned to the exhibitor for a show edition. Stored as xsd:string (mirrors im:scanBooth) because booth IDs may include letter prefixes even though IMTS 2024 booths are all numeric." .

im:name a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                  owl:unionOf ( im:Person im:Company ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "name" .

#-------------------------------------------------------------------------------
# Object properties — Mediation (sub-properties of gufo:mediates)
#-------------------------------------------------------------------------------
# gufo:mediates has rdfs:range gufo:Endurant, so every mediates target must be
# an Endurant (Aspect or Object). All four properties below satisfy this — the
# Visitor, Exhibitor, Employer, and Association are all Endurants. The show
# (an Event) is connected separately via im:manifestedInShow (not mediation).

im:mediatesVisitor a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:mediates ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  im:Visitor ;
    rdfs:label  "mediates visitor" .

im:mediatesExhibitor a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:mediates ;
    rdfs:domain im:ExhibitorRecord ;
    rdfs:range  im:Exhibitor ;
    rdfs:label  "mediates exhibitor" .

im:mediatesEmployer a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:mediates ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  im:Company ;
    rdfs:label  "mediates employer" .

im:mediatesAssociation a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:mediates ;
    rdfs:domain [ a owl:Class ;
                  owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  im:Association ;
    rdfs:label  "mediates association" ;
    rdfs:comment "Connects a Registration OR Membership to the organizing/owning Association that accepts it. For Registration this is the show organizer (im:AMT for IMTS); for Membership this is the association the member belongs to (im:AMT). Cardinality 1 on each Relator subject. Constrained to im:AMT in practice." .

im:mediatesMember a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:mediates ;
    rdfs:domain im:Membership ;
    rdfs:range  im:Member ;
    rdfs:label  "mediates member" ;
    rdfs:comment "Connects a Membership Relator to the Member Role it confers on a Company. Parallels im:mediatesVisitor / im:mediatesExhibitor for the registration-side. The Member side of the Membership Relator -- the other mandatory mediation is im:mediatesAssociation pointing at im:AMT." .

#-------------------------------------------------------------------------------
# Object properties — Show manifestation (sub-property of gufo:manifestedIn)
#-------------------------------------------------------------------------------
# gufo:manifestedIn has rdfs:domain gufo:Aspect, rdfs:range gufo:Event — the
# right gUFO property for "this Aspect is manifested in this Event". A
# Registration (a Relator, hence an Aspect) is manifested in the IMTS show
# where its participants come together. Using gufo:mediates here would fail
# the OWL DL check, since gufo:mediates' range is gufo:Endurant and Event /
# Endurant are disjoint under gufo:ConcreteIndividual.

im:manifestedInShow a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:manifestedIn ;
    rdfs:domain im:Registration ;
    rdfs:range  im:IMTS ;
    rdfs:label  "manifested in show" .

#-------------------------------------------------------------------------------
# Object properties — Lead (gufo:ExtrinsicMode anchoring)
#-------------------------------------------------------------------------------
# A Lead is an ExtrinsicMode: it inheres in the Exhibitor (its bearer) and
# externally depends on the Visitor (the relatum it is "about"). The Lead's
# existence is one-sided — the Exhibitor's scan creates it; the Visitor does
# not co-generate it. The BoothStaff who operated the scanner is captured as
# audit metadata only (NOT a UFO relatum): a Lead can exist without an
# identified BoothStaff (current scanners often capture exhibitor-only), and
# the Lead carries no information about the BoothStaff themselves.

im:leadOfExhibitor a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:inheresIn ;
    rdfs:domain im:Lead ;
    rdfs:range  im:Registration ;
    rdfs:label  "lead of exhibitor" ;
    rdfs:comment "Links a Lead (booth-scan event) to the Registration that operated the booth -- usually an im:ExhibitorRecord, occasionally an im:AmtFacility for badges scanned at AMT-operated venue spaces (member lounges, international lounge). Range widened from im:ExhibitorRecord to im:Registration so AmtFacility scans participate in the same exact-1 invariant." .

im:leadOfVisitor a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:externallyDependsOn ;
    rdfs:domain im:Lead ;
    rdfs:range  im:VisitorRecord ;
    rdfs:label  "lead of visitor" ;
    rdfs:comment "Links a Lead to the im:VisitorRecord (registration) whose badge was scanned. Range is the Relator (VisitorRecord), not the im:Visitor Role -- the scan identifies a registration, not the underlying person abstractly." .

im:leadCapturedBy a owl:ObjectProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  im:BoothStaff ;
    rdfs:label  "captured by" ;
    rdfs:comment "Audit metadata only: identifies the BoothStaff who operated the scanner, when known. Cardinality 0..1; not a UFO relator participant." .

#-------------------------------------------------------------------------------
# Object properties — Organizing (gufo:ExtrinsicMode anchoring)
#-------------------------------------------------------------------------------
# An Organizing is an ExtrinsicMode: it inheres in an ExhibitionDepartment
# (the organising Association's exhibition arm, e.g. AMT's) and is
# manifested in the IMTS edition it brings about. Asymmetric -- the
# Department performs it; IMTS is the result. Parallels the Lead pattern:
# one privileged Endurant bearer, one Event-side relatum.

im:organizedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:inheresIn ;
    rdfs:domain im:Organizing ;
    rdfs:range  im:ExhibitionDepartment ;
    rdfs:label  "organized by" .

im:organizesEvent a owl:ObjectProperty ;
    rdfs:subPropertyOf gufo:manifestedIn ;
    rdfs:domain im:Organizing ;
    rdfs:range  im:IMTS ;
    rdfs:label  "organizes event" .

#-------------------------------------------------------------------------------
# Object properties — Cross-ontology
#-------------------------------------------------------------------------------
# Both IM-side cross-ontology properties point at cmns-cds:CodeElement
# instances (form-side answer codes). Regular codes carry
# cmns-dsg:designates → pc class; sentinel codes (Other / No Response)
# carry no designates. Visitor records must reference pc_vcs CodeElements,
# exhibitor records pc_ecs CodeElements -- enforced in shapes/, not OWL.
# Industry classification on Company uses cmns-cls:isClassifiedBy directly
# (no codeset mediation), reflecting that Industry is single-shot
# classification while Interest/ProductCategory preserve a form-answer trail.

im:hasInterest a owl:ObjectProperty ;
    rdfs:domain  im:VisitorRecord ;
    rdfs:range   cmns-cds:CodeElement ;
    rdfs:label   "has interest" ;
    rdfs:comment "Connects a VisitorRecord to one or more cmns-cds:CodeElement instances representing the visitor's selected Product Category answers on the registration form. Membership scope (must be in pc_vcs:VisitorCodeSet) is enforced by imShape:VisitorInterestShape." .

im:hasLeadFormInterest a owl:ObjectProperty ;
    rdfs:domain  im:VisitorRecord ;
    rdfs:range   cmns-cds:CodeElement ;
    rdfs:label   "has lead-form interest" ;
    rdfs:comment "Visitor's selected product-interest answers on the lead-scan form (a pre-harmonization vocabulary distinct from the registration-form pc_vcs question). Membership scope enforced by imShape:VisitorLeadFormInterestShape against lead_pc_cs:LeadProductInterestCodeSet." .

im:hasProductCategory a owl:ObjectProperty ;
    rdfs:domain  im:Registration ;
    rdfs:range   cmns-cds:CodeElement ;
    rdfs:label   "has product category" ;
    rdfs:comment "Self-classification of an exhibitor's offering against a product-category vocabulary. Domain im:Registration (v0.6.1) covers im:ExhibitorRecord and external exhibitor Kinds that sit under im:Registration (e.g. pc_jimtof_cs:Exhibitor). The per-Kind constraint that ONLY exhibitor-side sub-Kinds use this property is enforced by SHACL shapes in shapes/codeset-shapes.ttl, since a bare rdfs:domain declaration would either miss the JIMTOF external class (if narrowed to im:ExhibitorRecord) or force im.ttl to import the external codeset (a reverse dependency we forbid)." .

#-------------------------------------------------------------------------------
# v0.4.0 additions -- ingestion-data properties (added for individuals build)
#-------------------------------------------------------------------------------
# These properties carry data captured from the Maritz registration platform
# (visitor_raw), the lead-scan questionnaire (leads_raw), and the exhibitor
# self-categorization workflow (exhibitor_raw). They populate VisitorRecord,
# ExhibitorRecord, Lead, and Company instances; the existing UFO mediation
# / inheresIn / externallyDependsOn / manifestedIn properties are unchanged.
#
# Five codeset-mediated object properties take ranges of cmns-cds:CodeElement
# and are membership-scoped to a specific CodeSet by SHACL shapes (see
# shapes/codeset-shapes.ttl, additions in v0.4.0):
#   im:registrationClass    -> imts_rc_cs:IMTSRegistrationCategoryCodeSet
#   im:hasIndustry          -> ind_cs:VisitorCodeSet
#   im:jobFunction          -> jobfn_cs:JobFunctionCodeSet
#   im:acquisitionRole      -> acqrole_cs:AcquisitionRoleCodeSet
#   im:plantEmployeeCount   -> empcount_cs:PlantEmployeeCountCodeSet
#
# Datatype properties carrying PII (im:firstName, im:lastName, im:email,
# im:streetAddress) are flagged in comments. The redaction script
# (scripts/redact_individuals.py, follow-up commit) drops them when
# producing test-fixture TTL files.

# --- VisitorRecord: personal identifying fields -----------------------------
# All PII; dropped in committed fixtures.

im:firstName a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "first name" ;
    rdfs:comment "PII. Sourced from visitor_raw.FirstName or leads_raw.\"First Name\". Dropped in pseudonymized fixtures." .

im:lastName a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "last name" ;
    rdfs:comment "PII. Sourced from visitor_raw.LastName or leads_raw.\"Last Name\". Dropped in pseudonymized fixtures." .

im:email a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "email" ;
    rdfs:comment "PII. Sourced from visitor_raw.Email or leads_raw.Email. Dropped in pseudonymized fixtures." .

im:title a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "title" ;
    rdfs:comment "Job title. Low-PII (frequently appears in public bios) but dropped in fixtures together with the name fields." .

# --- Address fields (shared: VisitorRecord home address + Company HQ address)
# Domain widened from im:VisitorRecord-only to (im:VisitorRecord ∪ im:Company)
# in v0.6.0 so AMT-member corporate HQ addresses can attach directly to the
# Company. Visitor-side values remain PII (dropped in pseudonymized fixtures);
# Company-side values are public corporate HQ addresses and NOT redacted.

im:streetAddress a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "street address" ;
    rdfs:comment "Relator-anchored: address-line snapshot captured by a Registration (the visitor / exhibitor home address as of show registration) or Membership (the member company's HQ as of the membership application). Multi-valued. Never attached to im:Company or im:Person directly -- the value is a property of the relationship instance, not of the substantial entity. On VisitorRecord: PII (visitor home); stripped in pseudonymized fixtures. On Membership: street-level corporate HQ; still semi-PII (granular building address); stripped in fixtures." .

im:city a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "city" ;
    rdfs:comment "Relator-anchored. On VisitorRecord / ExhibitorRecord: PII (visitor home / exhibitor company city as of registration); stripped in fixtures. On Membership: public corporate-HQ city as of membership application; kept in fixtures." .

im:stateProvince a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "state or province" ;
    rdfs:comment "Relator-anchored. Same Visitor-vs-Membership PII split as im:city." .

im:postalCode a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "postal code" ;
    rdfs:comment "Relator-anchored. Source may be numeric (US ZIP) or alphanumeric (Canadian, UK, etc.). Stored as string to preserve leading zeros. Same Visitor-vs-Membership PII split as im:city." .

im:country a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:string ;
    rdfs:label  "country" ;
    rdfs:comment "Relator-anchored. Same Visitor-vs-Membership PII split as im:city." .

# --- VisitorRecord: registration-flow fields --------------------------------

im:registrationDay a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:string ;
    rdfs:label  "registration day" ;
    rdfs:comment "Phase of the registration window: Pre-Reg / Day1 / etc. Sourced from visitor_raw.RegDay. Free-form string; small finite value set but not codeset-mediated (Status: pending value-table cleanup)." .

im:emailOptIn a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:boolean ;
    rdfs:label  "email opt-in" ;
    rdfs:comment "Whether the visitor opted in to marketing email. Sourced from visitor_raw.EmailOptIn (Y/N converted to xsd:boolean)." .

im:sourceProvenance a owl:DatatypeProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  xsd:string ;
    rdfs:label  "source provenance" ;
    rdfs:comment "Origin of the record. Domain im:Registration (v0.6.1, previously unset) covers any Registration sub-Kind. For VisitorRecord: \"registration\" (Maritz reg export) or \"leads\" (synthesized because badge was missing from reg export). For ExhibitorRecord: \"exhibitor_raw\" (Maritz exhibitor export) or \"leads\" (synthesized because the booth scanned in leads_raw was missing from exhibitor_raw). For AmtFacility: always \"leads\" (these are only discovered from scan data)." .

# --- VisitorRecord: object properties --------------------------------------

im:representsCompany a owl:ObjectProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  im:Company ;
    rdfs:label  "represents company" ;
    rdfs:comment "Links a record to its corporate entity. Domain im:Registration (v0.6.1) covers VisitorRecord, ExhibitorRecord, AmtFacility, and external exhibitor sub-Kinds (e.g. pc_jimtof_cs:Exhibitor). Target Company IRI is hash-derived from the normalized company name so identical companies across record types collapse to one entity." .

im:registeredForShow a owl:ObjectProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  im:TradeShow ;
    rdfs:label  "registered for show" ;
    rdfs:comment "Which trade-show edition this record belongs to. Domain im:Registration (v0.6.1) covers VisitorRecord, ExhibitorRecord, AmtFacility, and external exhibitor sub-Kinds (e.g. pc_jimtof_cs:Exhibitor). One event individual per edition." .

im:hasIndustry a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:VisitorRecord im:Company ) ] ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "has industry" ;
    rdfs:comment "Industry-group classification. On VisitorRecord: the industry the visitor reported on the lead-scan questionnaire (per-attendance self-report). On Company: the union of industries declared by every VisitorRecord whose im:representsCompany is this Company -- a derived aggregate. The two are kept in sync at ingest by scripts/build_individuals.py and enforced by TestCompanyHasAllVisitorIndustries. Multi-valued by design: a company whose visitors disagree on industry is faithfully tagged with all reported industries; downstream queries can pick a winner if needed. Range scoped to ind_cs:VisitorCodeSet members." .

im:registrationClass a owl:ObjectProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "registration class" ;
    rdfs:comment "Maritz platform's category code for the registrant (visitor / exhibitor / press / staff / cancelled / etc.). Range scoped to imts_rc_cs:IMTSRegistrationCategoryCodeSet members." .

im:jobFunction a owl:ObjectProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "job function" ;
    rdfs:comment "Visitor\u2019s primary job function. Range scoped to jobfn_cs:JobFunctionCodeSet members via SHACL." .

im:acquisitionRole a owl:ObjectProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "acquisition role" ;
    rdfs:comment "Visitor\u2019s role in the acquisition process (decision-maker, influencer, info-gatherer, etc.). Range scoped to acqrole_cs:AcquisitionRoleCodeSet members via SHACL." .

im:plantEmployeeCount a owl:ObjectProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "plant employee count" ;
    rdfs:comment "Bracketed total employees at the visitor\u2019s plant. Captured per visitor and stored on VisitorRecord (denormalized, same rationale as im:hasIndustry). Range scoped to empcount_cs:PlantEmployeeCountCodeSet members via SHACL." .

# --- Membership-side: bylaw role + primary business segment -----------------
# Attached to im:Membership (the Relator), NOT to im:Company or im:Member.
# Reason: these are answers to the Membership Application; if a company ever
# lapses and rejoins with a different MT Role / PPL, the new Membership
# instance records the change without re-typing the Company.

im:hasMTRole a owl:ObjectProperty ;
    rdfs:domain im:Membership ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "has MT role" ;
    rdfs:comment "Bylaw-defined classification of the member's relationship to the manufacturing-technology ecosystem (Builder / Distributor / Affiliate / Investor). Range scoped to mtrole_cs:MTRoleCodeSet members via SHACL. Captured on the Membership Application; sourced from Salesforce." .

im:hasPrimaryProductLine a owl:ObjectProperty ;
    rdfs:domain im:Membership ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "has primary product line" ;
    rdfs:comment "Member's coarse business-segment self-selection on the Membership Application. Range scoped to ppl_cs:PrimaryProductLineCodeSet members via SHACL. The Application also captures a secondary line into a separate field; im:hasSecondaryProductLine is deferred until that data lands -- see docs/decisions/im.md." .

# --- Exhibitor-side: products + industry coverage --------------------------

im:exhibits a owl:DatatypeProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  xsd:string ;
    rdfs:label  "exhibits" ;
    rdfs:comment "Specific product line(s) an exhibitor brings to a show. Free text, multi-valued. Distinct from im:hasProductCategory (vocabulary-level self-categorization). Domain im:Registration (v0.6.1) covers ExhibitorRecord and external exhibitor sub-Kinds (e.g. pc_jimtof_cs:Exhibitor). Per-Kind restriction to exhibitor-side subjects only is enforced by SHACL." .

im:servesIndustry a owl:ObjectProperty ;
    rdfs:domain im:Registration ;
    rdfs:range  cmns-cds:CodeElement ;
    rdfs:label  "serves industry" ;
    rdfs:comment "Industries an exhibitor targets or serves with its products. Multi-valued, codeset-mediated (each show's codeset scope enforced via SHACL). Distinct from im:hasIndustry, which is the visitor-side question (the visitor's own company industry). Domain im:Registration (v0.6.1) covers ExhibitorRecord and external exhibitor sub-Kinds (e.g. pc_jimtof_cs:Exhibitor); per-Kind restriction enforced by SHACL." .

im:recordCreatedAt a owl:DatatypeProperty ;
    rdfs:domain im:VisitorRecord ;
    rdfs:range  xsd:dateTime ;
    rdfs:label  "record created at" ;
    rdfs:comment "Database timestamp when the registration record was created. Distinct from im:registrationDate (the visitor's actual registration moment) and from im:scanDateTime (per-Lead scan time)." .

im:companyURL a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( im:Registration im:Membership ) ] ;
    rdfs:range  xsd:anyURI ;
    rdfs:label  "company URL" ;
    rdfs:comment "Relator-anchored: the company's primary web URL as captured by a specific relationship-instance (a lead-scan Registration's snapshot, or the Membership's snapshot at application time). Domain widened from im:Company to (im:Registration ∪ im:Membership) in v0.6.1 -- the URL is treated as a per-source snapshot rather than an identity-level fact, so different sources can record different URLs over time (rebrands, mergers) without conflict. The Company itself stays identity-only; to read the current URL for a Company, traverse ^im:mediatesMember/im:companyURL through its Membership." .


# --- ExhibitorRecord: additions ---------------------------------------------

im:categorizationDate a owl:DatatypeProperty ;
    rdfs:domain im:ExhibitorRecord ;
    rdfs:range  xsd:dateTime ;
    rdfs:label  "categorization date" ;
    rdfs:comment "When the exhibitor self-categorized into its product categories on the Maritz platform." .

# --- Lead: scan-payload additions ------------------------------------------
# These are *scan*-specific datatype/object properties. The existing
# UFO-anchored object properties im:leadOfVisitor / im:leadOfExhibitor /
# im:leadCapturedBy connect Lead to the Visitor/Exhibitor *Roles*; the
# data joins below connect Lead to the concrete *Records* (which carry
# badge, address, etc.) for query convenience.

im:eventCode a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:string ;
    rdfs:label  "event code" ;
    rdfs:comment "Maritz EventCode the scan belongs to, e.g. \"IMTS0924\". Identifies the specific show edition; resolves transitively to im:IMTS via the ExhibitorRecord\u2019s im:registeredForShow if needed." .

im:scanDateTime a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:dateTime ;
    rdfs:label  "scan date-time" ;
    rdfs:comment "Timestamp of the badge scan that created this Lead. Sourced from leads_raw.\"Scan date/time\"." .

im:scanHall a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:string ;
    rdfs:label  "scan hall" ;
    rdfs:comment "Show-hall identifier where the scan occurred, e.g. \"South Building, Level 3\". Sourced from leads_raw.Hall." .

im:scanBooth a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:string ;
    rdfs:label  "scan booth" ;
    rdfs:comment "Booth number where the scan occurred. Sourced from leads_raw.\"Booth Number\". Stored as xsd:string (booth IDs may eventually include letter prefixes even though IMTS 2024 booth IDs are all numeric)." .

im:scanPavilion a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:string ;
    rdfs:label  "scan pavilion" ;
    rdfs:comment "Pavilion (Parent Category) where the scan occurred. Sourced from leads_raw.Pavilion. Mirrors exhibitor_raw.\"Parent Category\" \u2014 the 21 IMTS Exhibitor pavilion names." .

im:terminalID a owl:DatatypeProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  xsd:string ;
    rdfs:label  "terminal ID" ;
    rdfs:comment "Maritz scanner-device identifier, e.g. \"2430741_IMTS0924_API\". Audit/traceability; not a UFO relator participant. Sourced from leads_raw.TerminalID." .

im:leadFrom a owl:ObjectProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  im:VisitorRecord ;
    rdfs:label  "lead from" ;
    rdfs:comment "Data join: links a Lead to the VisitorRecord identified by leads_raw.Badge. Complements (does not replace) im:leadOfVisitor, which connects to the im:Visitor *Role*; im:leadFrom connects to the concrete *Record* carrying badge/name/address." .

im:leadOf a owl:ObjectProperty ;
    rdfs:domain im:Lead ;
    rdfs:range  im:ExhibitorRecord ;
    rdfs:label  "lead of" ;
    rdfs:comment "Data join: links a Lead to the ExhibitorRecord identified by leads_raw.CompanyID. Complements (does not replace) im:leadOfExhibitor, which connects to the im:Exhibitor *Role*." .


#-------------------------------------------------------------------------------
# Object properties — Domain relations
#-------------------------------------------------------------------------------

im:staffsFor a owl:ObjectProperty ;
    rdfs:domain im:BoothStaff ;
    rdfs:range  im:Exhibitor ;
    rdfs:label  "staffs for" .

#-------------------------------------------------------------------------------
# Disjointness axioms — gUFO Kind partition
#-------------------------------------------------------------------------------
# UFO requires every individual to instantiate exactly one Kind. OWL does not
# enforce this on its own; the axioms below make the partition explicit so OWL
# reasoners (and SHACL via sh:not / sh:disjoint) can flag violations.
#
# Role-level disjointness follows from Kind-level disjointness and need not be
# asserted separately:
#   im:Visitor ⊑ im:Person  and  im:Exhibitor ⊑ im:Company
#   im:Person  ⟂ im:Company  ⇒  im:Visitor ⟂ im:Exhibitor
# (Note: im:BoothStaff ⊑ im:Visitor by design, so they are NOT disjoint.
#  im:Member ⊑ im:Company by design, so Member ⟂ Visitor follows from
#  Company ⟂ Person.)

[] a owl:AllDisjointClasses ;
   owl:members ( im:Person im:Company im:Association im:Department ) .

im:VisitorRecord owl:disjointWith im:ExhibitorRecord .
im:Registration  owl:disjointWith im:Lead .
im:Registration  owl:disjointWith im:Membership .

#-------------------------------------------------------------------------------
# Cardinality restrictions
#-------------------------------------------------------------------------------

# Person identity
im:Person rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:name ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# Company identity
im:Company rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:name ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# BoothStaff sub-role anchors to a specific Exhibitor
im:BoothStaff rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:staffsFor ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# Department is a component of exactly one Organization — every department
# (Exhibition or otherwise) is part of one parent organization. The parent
# MUST be an im:Organization (Association OR Company); a Department cannot
# be componentOf, say, a Person or another Department. Uses
# owl:qualifiedCardinality to constrain both arity and range of
# gufo:isComponentOf in a single restriction.
im:Department rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty           gufo:isComponentOf ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass              im:Organization ] .

# Registration identity (inherited by VisitorRecord and ExhibitorRecord)
im:Registration rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:uuid                ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:registrationDate    ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:manifestedInShow    ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:mediatesAssociation ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# VisitorRecord constraints
im:VisitorRecord rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:badge            ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:mediatesVisitor  ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:mediatesEmployer ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:hasInterest      ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# ExhibitorRecord constraints
im:ExhibitorRecord rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:booth              ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:mediatesExhibitor  ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:hasProductCategory ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# Lead constraints
im:Lead rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:leadOfVisitor   ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:leadOfExhibitor ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:leadCapturedBy  ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] .

# Organizing: every Organizing instance inheres in exactly one
# ExhibitionDepartment (its bearer) and is manifested in exactly one IMTS
# edition.
im:Organizing rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:organizedBy     ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:organizesEvent  ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# Membership constraints: every Membership instance mediates exactly one Member
# and one Association, and carries exactly one Primary Product Line. MT Role
# is optional (max-1, enforced in SHACL only) because the current AMT
# membership export does not carry MT Role values for each row -- they live
# in a separate Salesforce field that hasn't been joined into the export yet.
# OWL minCardinality below; the exact-1 invariant is enforced in shapes/
# (parallels the SHACL exact-1 pattern used for Visitor / Exhibitor records).
im:Membership rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty im:mediatesMember        ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:mediatesAssociation   ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:hasMTRole             ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ; owl:onProperty im:hasPrimaryProductLine ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] .
