#------------------------------------------------------------------------------
# Special CodeElements
#------------------------------------------------------------------------------

# Free-text sentinel: "Other (Please specify)". Does not designate any
# canonical pc class (no pc:Other Classifier -- "Other" is a form-
# interaction concept, not a taxonomy concept). Typed as
# amtmeta:SentinelCodeElement with amtmeta:promptsFreeText "true" to
# distinguish from absence-of-answer sentinels.
pc_ecs:codeOther
    a cmns-cds:CodeElement, amtmeta:SentinelCodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf      pc_ecs:ExhibitorCodeSet ;
    pc_ecs:demoId            2 ;
    skos:notation            "ETBDOther"^^xsd:token ;
    skos:prefLabel           "Other (Please specify)" ;
    amtmeta:promptsFreeText  "true"^^xsd:boolean .

# Absence-of-answer sentinel: "No Response".
pc_ecs:codeNoResponse
    a cmns-cds:CodeElement, amtmeta:SentinelCodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf pc_ecs:ExhibitorCodeSet ;
    pc_ecs:demoId       2 ;
    skos:notation       "ETBDNoResponse"^^xsd:token ;
    skos:prefLabel      "No Response" .
