@prefix lead_pc_cs:  <http://ontology.amt.org/codes/lead-product-interest#> .
@prefix amtmeta:     <http://ontology.amt.org/meta#> .
@prefix pc_vcs:      <http://ontology.amt.org/codes/visitor-product-categories#> .
@prefix cmns-cds:    <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col:    <https://www.omg.org/spec/Commons/Collections/> .
@prefix cmns-dsg:    <https://www.omg.org/spec/Commons/Designators/> .
@prefix owl:         <http://www.w3.org/2002/07/owl#> .
@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:        <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:     <http://purl.org/dc/terms/> .

# ============================================================================
# Lead-Scan Product-Interest CodeSet
# ============================================================================
# Pre-harmonization visitor-form product-interest vocabulary as it stood for
# IMTS 2024. Each entry corresponds to one row of "Page 2 Updates" in
# old_visitor_categories_mapped.xlsx; the Answer ID is preserved as
# skos:notation.
#
# cmns-dsg:designates targets pc_vcs: CodeElements (the harmonized visitor
# codeset), giving a same-context old->new answer-ID mapping. The pc:
# class anchor is reached transitively through pc_vcs's own designates.
# When the harmonized target is a bucket-level grouping, the designate
# points at the pc_vcs:bucket* Collection.
#
# Entries marked owl:deprecated true are retired in the harmonized model
# (Action=REMOVE) or were manually retired post-harmonization. Their
# notations remain so historical lead-scan data still resolves.
# ============================================================================

<http://ontology.amt.org/codes/lead-product-interest>
    a owl:Ontology, amtmeta:CodeSetVocabulary ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://ontology.amt.org/product-categories>,
                <https://www.omg.org/spec/Commons/CodesAndCodeSets/>,
                <https://www.omg.org/spec/Commons/Collections/>,
                <https://www.omg.org/spec/Commons/Designators/> ;

    dcterms:title    "Lead-Scan Product Interest CodeSet" ;
    owl:versionInfo  "0.5.0" ;
    owl:versionIRI   <http://ontology.amt.org/codes/lead-product-interest/0.5.0> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Chris Downs" ;
    amtmeta:technicalSteward    "Shaurabh" ;
    amtmeta:relatedProduct      "IMTS Lead Scan" ;
    amtmeta:nextReviewDate      "2027-01-01"^^xsd:date ;

    amtmeta:releaseDate     "2026-06-12"^^xsd:date ;
    amtmeta:scopeSummary    "IMTS 2024 lead-scan-form product-interest vocabulary; CodeElement notations are Answer IDs from old_visitor_categories_mapped.xlsx. cmns-dsg:designates targets pc_vcs: CodeElements; deprecated entries (REMOVE / manually retired) retain notation for historical data resolution." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.5.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.5.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.5.0> ;

    amtmeta:useCase
        "Capture visitors' 2024 lead-scan-form product-interest selections; trace to the harmonized visitor codeset via cmns-dsg:designates" .

lead_pc_cs:LeadProductInterestConcept
    a amtmeta:Collection, owl:NamedIndividual ;
    rdfs:label   "Lead-Scan Product Interest" ;
    rdfs:comment "Anchor for amtmeta:codesFor on lead_pc_cs:LeadProductInterestCodeSet." .

lead_pc_cs:LeadProductInterestCodeSet
    a cmns-cds:CodeSet, owl:NamedIndividual ;
    amtmeta:codesFor    lead_pc_cs:LeadProductInterestConcept ;
    rdfs:label          "Lead-Scan Product Interest CodeSet" ;
    amtmeta:consumerFor "IMTS Lead Scan registration question: product interest (2024)" ;
    rdfs:comment        "Pre-harmonization lead-scan-form product-interest vocabulary." .

