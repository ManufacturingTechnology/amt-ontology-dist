lead_pc_cs:codeTurningAndLathes
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf lead_pc_cs:LeadProductInterestCodeSet ;
    skos:notation       "3A"^^xsd:token ;
    skos:prefLabel      "Turning and Lathes" ;
    cmns-dsg:designates pc_vcs:bucketTurningScrewMachiningAndThreadManufacturing ;
    skos:editorialNote  "harmonization-action: Update" .
