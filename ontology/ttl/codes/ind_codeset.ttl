#-------------------------------------------------------------------------------
# Special CodeElements
#-------------------------------------------------------------------------------

# 1T "Other (Please specify)" -- free-text sentinel. Does NOT designate
# any canonical Industry Classifier (ind.ttl is intentionally exactly 17
# industries; "Other" is a form-interaction concept, not a taxonomy one).
# Typed as amtmeta:SentinelCodeElement (the umbrella class for codes
# that record meta-facts rather than designate canonical concepts);
# distinguished from absence-of-answer sentinels by
# amtmeta:promptsFreeText "true", which tells downstream tools to
# capture the user-supplied string at the form / storage layer.
# Carries skos:prefLabel locally because there is no canonical concept
# to walk to for a display label.
ind_cs:codeOther
    a cmns-cds:CodeElement, amtmeta:SentinelCodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf      ind_cs:VisitorCodeSet ;
    ind_cs:demoId            1 ;
    skos:notation            "1T"^^xsd:token ;
    skos:prefLabel           "Other (Please specify)" ;
    amtmeta:promptsFreeText  "true"^^xsd:boolean .

# ZZ "No Response" -- absence-of-answer sentinel. Does NOT designate any
# canonical concept; records the explicit absence of an answer. No
# amtmeta:promptsFreeText flag (the form does not capture text when a
# user opts out). Carries skos:prefLabel locally because there is no
# canonical concept to walk to for a display label.
ind_cs:codeNoResponse
    a cmns-cds:CodeElement, amtmeta:SentinelCodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf ind_cs:VisitorCodeSet ;
    ind_cs:demoId       1 ;
    skos:notation       "ZZ"^^xsd:token ;
    skos:prefLabel      "No Response" .
