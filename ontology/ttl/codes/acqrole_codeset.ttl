@prefix acqrole_cs: <http://ontology.amt.org/codes/acquisition-role#> .
@prefix amtmeta:    <http://ontology.amt.org/meta#> .
@prefix cmns-cds:   <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col:   <https://www.omg.org/spec/Commons/Collections/> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:       <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:    <http://purl.org/dc/terms/> .

# ============================================================================
# Acquisition Role CodeSet
# ============================================================================
# Controlled vocabulary for the IMTS lead-scan questionnaire field
# "What roles do you play in the acquisition process?". 6 substantive
# categories + 1 sentinel (No Response).
#
# PLACEHOLDER METADATA -- governance owner/consumers/use-cases TBD.
# Entry IDs (AR01..AR07) are placeholder; replace with form-side IDs
# once available.
# ============================================================================

<http://ontology.amt.org/codes/acquisition-role>
    a owl:Ontology, amtmeta:CodeSetVocabulary ;
    owl:imports <http://ontology.amt.org/meta>,
                <https://www.omg.org/spec/Commons/CodesAndCodeSets/>,
                <https://www.omg.org/spec/Commons/Collections/> ;

    dcterms:title    "Acquisition Role CodeSet" ;
    owl:versionInfo  "0.1.0" ;
    owl:versionIRI   <http://ontology.amt.org/codes/acquisition-role/0.1.0> ;

    amtmeta:status              amtmeta:Draft ;
    amtmeta:taxonomyOwner       "TBD" ;
    amtmeta:governedBy          "TBD" ;
    amtmeta:consumedBy          "TBD" ;
    amtmeta:technicalSteward    "TBD" ;

    amtmeta:relatedProduct      "IMTS Lead Retrieval" ;
    amtmeta:relatedSystem       "Maritz Reg Platform (Primary Source)" ;

    amtmeta:nextReviewDate      "2026-10-01"^^xsd:date ;

    amtmeta:releaseDate     "2026-06-11"^^xsd:date ;
    amtmeta:scopeSummary    "v0.1.0 -- PLACEHOLDER. Acquisition-role categories derived from observed values in the IMTS lead-scan questionnaire. 6 substantive codes (AR01..AR06) + 'No Response' sentinel. Entry IDs and metadata are placeholders pending the taxonomy owner's confirmation." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.1.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;

    amtmeta:useCase         "TBD" .

#-------------------------------------------------------------------------------
# Anchor individual (amtmeta:codesFor target)
#-------------------------------------------------------------------------------
# Identifies what this codeset is a code set OF. Required by the SHACL
# CodeSetCodesForShape ({Every cmns-cds:CodeSet must carry exactly one
# amtmeta:codesFor}). For CodeElement-direct codesets like this one,
# the anchor has no further structure -- it's just a stable identifier
# for the concept the codes collectively express.

acqrole_cs:AcquisitionRoleConcept
    a amtmeta:Collection, owl:NamedIndividual ;
    rdfs:label   "Acquisition Role" ;
    rdfs:comment "Anchor individual for amtmeta:codesFor on acqrole_cs:AcquisitionRoleCodeSet. Has no internal structure: CodeElements in this codeset carry their own skos:prefLabel directly, so no underlying Classifier hierarchy is asserted." .

#-------------------------------------------------------------------------------
# CodeSet
#-------------------------------------------------------------------------------

acqrole_cs:AcquisitionRoleCodeSet
    a cmns-cds:CodeSet, owl:NamedIndividual ;
    amtmeta:codesFor    acqrole_cs:AcquisitionRoleConcept ;
    rdfs:label          "Acquisition Role CodeSet" ;
    amtmeta:consumerFor "IMTS Lead-Scan Questionnaire (acquisition role)" ;
    rdfs:comment        "Answer set for the lead-scan acquisition-role question. Used as the range of im:acquisitionRole on VisitorRecord." .

#-------------------------------------------------------------------------------
# 7 Acquisition Role CodeElements (6 substantive + 1 sentinel)
#-------------------------------------------------------------------------------

acqrole_cs:codeGatherInfo
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR01"^^xsd:token ;
    skos:prefLabel      "Gather information to evaluate alternative products" .

acqrole_cs:codeNoRole
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR02"^^xsd:token ;
    skos:prefLabel      "Have no role in buying the products shown" .

acqrole_cs:codeIdentifyNeed
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR03"^^xsd:token ;
    skos:prefLabel      "Identify the need for new products or equipment" .

acqrole_cs:codeJointDecision
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR04"^^xsd:token ;
    skos:prefLabel      "Jointly make a buying decision with others" .

acqrole_cs:codeJustifyOrSelect
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR05"^^xsd:token ;
    skos:prefLabel      "Justify the purchase and/or select a specific brand" .

acqrole_cs:codeFinalDecision
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR06"^^xsd:token ;
    skos:prefLabel      "Make the final decision or give the final approval" .

acqrole_cs:codeNoResponse
    a cmns-cds:CodeElement, amtmeta:SentinelCodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf acqrole_cs:AcquisitionRoleCodeSet ;
    skos:notation       "AR07"^^xsd:token ;
    skos:prefLabel      "No Response" .
