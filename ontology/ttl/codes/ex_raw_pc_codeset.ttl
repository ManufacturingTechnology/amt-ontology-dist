@prefix ex_raw_pc_cs:<http://ontology.amt.org/codes/exhibitor-raw-product-categories#> .
@prefix amtmeta:     <http://ontology.amt.org/meta#> .
@prefix pc_ecs:      <http://ontology.amt.org/codes/exhibitor-product-categories#> .
@prefix cmns-cds:    <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col:    <https://www.omg.org/spec/Commons/Collections/> .
@prefix cmns-dsg:    <https://www.omg.org/spec/Commons/Designators/> .
@prefix owl:         <http://www.w3.org/2002/07/owl#> .
@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:        <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:     <http://purl.org/dc/terms/> .

# ============================================================================
# IMTS 2024 Raw Exhibitor Product-Category CodeSet
# ============================================================================
# Full snapshot of the 2024 IMTS exhibitor catalog vocabulary
# (pre-harmonization). Each distinct Maritz Category ID gets one CodeElement
# with notation = Maritz ID and prefLabel = the verbatim 2024 catalog text.
#
# cmns-dsg:designates targets pc_ecs CodeElements (the harmonized exhibitor
# codeset), giving a same-context old->new mapping. The pc: class anchor is
# reached transitively via pc_ecs's own designates.
#
# Entries marked owl:deprecated true are retired in the harmonized model
# (Action = removed in old_exhibitor_categories_mapped.xlsx); their
# notations remain so historical 2024 exhibitor data still resolves.
# ============================================================================

<http://ontology.amt.org/codes/exhibitor-raw-product-categories>
    a owl:Ontology, amtmeta:CodeSetVocabulary ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://ontology.amt.org/product-categories>,
                <https://www.omg.org/spec/Commons/CodesAndCodeSets/>,
                <https://www.omg.org/spec/Commons/Collections/>,
                <https://www.omg.org/spec/Commons/Designators/> ;

    dcterms:title    "IMTS 2024 Raw Exhibitor Product-Category CodeSet" ;
    owl:versionInfo  "0.3.0" ;
    owl:versionIRI   <http://ontology.amt.org/codes/exhibitor-raw-product-categories/0.3.0> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Chris Downs" ;
    amtmeta:technicalSteward    "Shaurabh" ;
    amtmeta:relatedProduct      "IMTS Exhibitor Catalog (raw)" ;
    amtmeta:nextReviewDate      "2027-01-01"^^xsd:date ;

    amtmeta:releaseDate     "2026-06-12"^^xsd:date ;
    amtmeta:scopeSummary    "Full 2024 IMTS exhibitor catalog vocabulary, pre-harmonization. cmns-dsg:designates targets pc_ecs CodeElements (same-context old->new mapping); pc: anchors reach via pc_ecs's own designates. Retired entries marked owl:deprecated true." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.3.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.3.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.3.0> ;

    amtmeta:useCase
        "Capture 2024 exhibitor catalog vocabulary; trace to the harmonized pc_ecs / pc: model via cmns-dsg:designates" .

ex_raw_pc_cs:ExhibitorRawProductCategoryConcept
    a amtmeta:Collection, owl:NamedIndividual ;
    rdfs:label   "Exhibitor Raw Product Category (IMTS 2024)" ;
    rdfs:comment "Anchor for amtmeta:codesFor on ex_raw_pc_cs:ExhibitorRawCodeSet." .

ex_raw_pc_cs:ExhibitorRawCodeSet
    a cmns-cds:CodeSet, owl:NamedIndividual ;
    amtmeta:codesFor    ex_raw_pc_cs:ExhibitorRawProductCategoryConcept ;
    rdfs:label          "Exhibitor Raw Product-Category CodeSet (IMTS 2024)" ;
    amtmeta:consumerFor "IMTS Exhibitor Application: 2024 catalog product categories" ;
    rdfs:comment        "2024 IMTS exhibitor catalog vocabulary." .

