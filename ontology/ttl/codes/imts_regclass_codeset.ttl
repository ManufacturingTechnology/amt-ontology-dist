@prefix imts_rc_cs: <http://ontology.amt.org/codes/imts-registration-category#> .
@prefix amtmeta:    <http://ontology.amt.org/meta#> .
@prefix cmns-cds:   <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col:   <https://www.omg.org/spec/Commons/Collections/> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:       <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:    <http://purl.org/dc/terms/> .

# ============================================================================
# IMTS Registration Category CodeSet
# ============================================================================
# Controlled vocabulary used by the Maritz registration platform to classify
# every IMTS registrant by role (visitor, exhibitor, press, staff, etc.).
# Drives downstream segmentation in Hubspot, Passport, MYS, and the AMT
# data warehouse.
#
# Pattern: CodeElement-only (no underlying Classifier layer like
# ind_codeset has). Each code carries skos:prefLabel directly because
# the codes ARE the categories -- there's no separate "thing being
# classified" to point at.
# ============================================================================

<http://ontology.amt.org/codes/imts-registration-category>
    a owl:Ontology, amtmeta:CodeSetVocabulary ;
    owl:imports <http://ontology.amt.org/meta>,
                <https://www.omg.org/spec/Commons/CodesAndCodeSets/>,
                <https://www.omg.org/spec/Commons/Collections/> ;

    dcterms:title    "IMTS Registration Category CodeSet" ;
    owl:versionInfo  "0.1.0" ;
    owl:versionIRI   <http://ontology.amt.org/codes/imts-registration-category/0.1.0> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Holly Pope" ;
    amtmeta:governedBy          "Michelle" ;
    amtmeta:consumedBy          "Marketing", "Passport", "Allison", "Tiffany", "Kevin", "MYS" ;
    amtmeta:technicalSteward    "Dev Ops" ;

    amtmeta:relatedProduct
        "Exhibitor Passport" ;

    amtmeta:relatedSystem
        "Maritz Reg Platform (Primary Source)",
        "Hubspot",
        "Data warehouse",
        "MYS" ;

    amtmeta:nextReviewDate      "2026-10-01"^^xsd:date ;

    amtmeta:releaseDate     "2026-06-11"^^xsd:date ;
    amtmeta:scopeSummary    "v0.1.0 -- initial CodeSet for the Maritz registration platform's RegClass / Registration Type field. 48 codes covering visitor sub-types, exhibitor sub-types, press, staff (AMT/Association/EAC/Distributor/Vendor), cancellation/duplicate/problem states, and lifecycle states (pending/approved). CodeElement-only model (no Classifier layer) because the codes are themselves the categories." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.1.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;

    amtmeta:useCase
        "IMTS Registration (Primary Source) - Registration category classifies registrants by role (attendee, exhibitor, press, staff, etc.)",
        "Marketing - HubSpot uses registration categories to segment attendees and exhibitors for targeted campaigns.",
        "Passport - Lead API - Exhibitor lead scans are imported into Passport accounts via API every 15 minutes.",
        "Passport Visitor Lists - Registration categories determine what attendee data appears in exhibitor visitor lists.",
        "Exhibitor Services - Registration data supports exhibitor performance analysis and communications with exhibitors.",
        "Research / Analytics - Registration data is integrated into the AMT Data Warehouse and used for Power BI reporting. Internal staff also use Maritz XPress Reports and Maritz DataSense Platform.",
        "MapYourShow (MYS) - Booth assignments create the Maritz exhibitor primary contact record via nightly API integration.",
        "Exhibitor Lead Portal - Registration categories determine which exhibitor staff can access the Maritz lead retrieval ordering site and exhibitor lead management portal." .

#-------------------------------------------------------------------------------
# Anchor individual (amtmeta:codesFor target)
#-------------------------------------------------------------------------------
# Identifies what this codeset is a code set OF. Required by the SHACL
# CodeSetCodesForShape ({Every cmns-cds:CodeSet must carry exactly one
# amtmeta:codesFor}). For CodeElement-direct codesets like this one,
# the anchor has no further structure -- it's just a stable identifier
# for the concept the codes collectively express.

imts_rc_cs:RegistrationCategory
    a amtmeta:Collection, owl:NamedIndividual ;
    rdfs:label   "IMTS Registration Category" ;
    rdfs:comment "Anchor individual for amtmeta:codesFor on imts_rc_cs:IMTSRegistrationCategoryCodeSet. Has no internal structure: CodeElements in this codeset carry their own skos:prefLabel directly, so no underlying Classifier hierarchy is asserted." .

#-------------------------------------------------------------------------------
# CodeSet
#-------------------------------------------------------------------------------

imts_rc_cs:IMTSRegistrationCategoryCodeSet
    a cmns-cds:CodeSet, owl:NamedIndividual ;
    amtmeta:codesFor    imts_rc_cs:RegistrationCategory ;
    rdfs:label          "IMTS Registration Category CodeSet" ;
    amtmeta:consumerFor "IMTS Registration (Maritz)" ;
    rdfs:comment        "All 49 registration category codes used by the Maritz IMTS registration platform. Each CodeElement carries skos:prefLabel directly (no underlying Classifier). Used as the range of im:registrationClass on VisitorRecord." .

#-------------------------------------------------------------------------------
# 49 Registration Category CodeElements
# (Ordered as provided by the taxonomy owner.)
#-------------------------------------------------------------------------------

imts_rc_cs:codeAA
    a cmns-cds:CodeElement, owl:NamedIndividual ;
    cmns-col:isMemberOf imts_rc_cs:IMTSRegistrationCategoryCodeSet ;
    skos:notation       "AA"^^xsd:token ;
    skos:prefLabel      "Interntl Association Staff" .

