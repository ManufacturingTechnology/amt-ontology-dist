@prefix pc_vcs:   <http://ontology.amt.org/codes/visitor-product-categories#> .
@prefix pc:       <http://ontology.amt.org/product-categories#> .
@prefix amtmeta:  <http://ontology.amt.org/meta#> .
@prefix cmns-cds: <https://www.omg.org/spec/Commons/CodesAndCodeSets/> .
@prefix cmns-col: <https://www.omg.org/spec/Commons/Collections/> .
@prefix cmns-dsg: <https://www.omg.org/spec/Commons/Designators/> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .

# ============================================================================
# Product Category Code Set -- IMTS Visitor Registration
# ============================================================================
# Replaces the retired visitor_view.ttl. Models the Product Category
# demographic question on IMTS Visitor Registration as a Commons CodeSet
# vocabulary: one root cmns-cds:CodeSet (pc_vcs:VisitorCodeSet), one cmns-cds:CodeElement per
# pc: leaf referenced by the AMT-curated Major/Sub bucket hierarchy.
# Buckets are amtmeta:Collection individuals authored locally (same
# shape as the retired view file) so the existing exporter algorithm
# (walk amtmeta:groups+ from top-level Collections) transfers with a
# graph-target swap only.
#
# Display text comes from the designated pc class's skos:prefLabel.
# Two special CodeElements at the bottom:
#   * pc_vcs:codeOther       -- free-text sentinel
#                       (amtmeta:SentinelCodeElement + promptsFreeText)
#   * pc_vcs:codeNoResponse  -- absence-of-answer sentinel
#
# *** Placeholder notations ***
# The skos:notation values below ("V001", "V002", ...) are TEMPORARY.
# Replace with real AMT-managed Answer IDs from the Product Interest
# Category workbook when they are available. The demoId value (2)
# is also a placeholder; the real Demo question ID will be supplied
# alongside the Answer IDs.
# ============================================================================

<http://ontology.amt.org/codes/visitor-product-categories>
    a owl:Ontology, amtmeta:CodeSetVocabulary ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://ontology.amt.org/product-categories>,
                <https://www.omg.org/spec/Commons/CodesAndCodeSets/>,
                <https://www.omg.org/spec/Commons/Collections/>,
                <https://www.omg.org/spec/Commons/Designators/> ;

    dcterms:title    "Visitor Registration Product Category CodeSet" ;
    owl:versionInfo  "0.1.0" ;
    owl:versionIRI   <http://ontology.amt.org/codes/visitor-product-categories/0.1.0> ;

    amtmeta:status                    amtmeta:Active ;
    amtmeta:taxonomyOwner             "Chris Downs" ;
    amtmeta:technicalSteward          "Shaurabh" ;
    amtmeta:governedBy                "Allison", "Ryan", "Downs" ;
    amtmeta:consumedBy                "Kristin", "Mark K", "Jess", "Allison", "Downs", "Alka", "Kalesh" ;
    amtmeta:relatedProduct            "IMTS (visitor reg and exhibitor categories/showrooms)", "Passport", "Media Sponsorships (media kit)" ;
    amtmeta:relatedSystem             "Maritz", "Hubspot", "Data warehouse", "Passport", "Exhibitor Space Application (linked at major category)" ;
    amtmeta:nextReviewDate      "2026-06-01"^^xsd:date ;
    amtmeta:nextReviewNote      "Need to discuss for Space Application." ;
    amtmeta:relatedDocumentation <https://amtonline.sharepoint.com/sites/governance/Shared%20Documents/Taxonomy%20Change%20Process.docx> ;

    amtmeta:releaseDate     "2026-05-26"^^xsd:date ;
    amtmeta:scopeSummary    "v0.1.0 -- initial CodeSet replacing visitor_view.ttl. Models IMTS Visitor Registration's Product Category demographic as 156 cmns-cds:CodeElement individuals (one per leaf pc class or catalog-residual Collection referenced by the AMT-curated bucket hierarchy), grouped via 26 amtmeta:Collection buckets mirroring the Major/Sub structure. Plus one free-text Other sentinel and one No Response sentinel. Notations and demoId are placeholders pending the AMT-managed Answer ID dump." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.1.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;

    amtmeta:useCase
        "Marketing uses this for targeted marketing",
        "Passport uses this as a filter to create lists",
        "IMTS uses this as a demographic field for visitor registration",
        "IMTS uses this in post-show reporting",
        "IMTS uses this to create exhibitor product categories".

#------------------------------------------------------------------------------
# Local property
#------------------------------------------------------------------------------

pc_vcs:demoId a owl:DatatypeProperty ;
    rdfs:label   "demo question ID" ;
    rdfs:range   xsd:positiveInteger ;
    rdfs:comment "Form-level question identifier. Placeholder value 2 used for all elements until the real Demo question ID is supplied." .

#------------------------------------------------------------------------------
# Root CodeSet
#------------------------------------------------------------------------------

pc_vcs:VisitorCodeSet
    a cmns-cds:CodeSet, owl:NamedIndividual ;
    rdfs:label          "Visitor Registration Product Category CodeSet" ;
    amtmeta:codesFor    pc:ProductCategory ;
    amtmeta:consumerFor "IMTS Visitor Registration" ;
    rdfs:comment        "Root CodeSet for the IMTS Visitor Registration Product Category form question. Buckets organising the codes live in this same file as amtmeta:Collection individuals." .

