<http://ontology.amt.org/product-categories>
    a owl:Ontology, amtmeta:Taxonomy ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://purl.org/nemo/gufo> ;

    dcterms:title    "Manufacturing Product Categories Ontology" ;
    owl:versionInfo  "0.1.1" ;
    owl:versionIRI   <http://ontology.amt.org/product-categories/0.1.1> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Chris Downs" ;
    amtmeta:governedBy          "Allison", "Ryan", "Downs" ;
    amtmeta:consumedBy          "Kristin", "Mark K", "Jess", "Allison",
                                "Downs", "Alka", "Kalesh" ;
    amtmeta:technicalSteward    "Shaurabh" ;

    amtmeta:relatedProduct
        "IMTS (visitor reg and exhibitor categories/showrooms)",
        "Passport",
        "Media Sponsorships (media kit)" ;

    amtmeta:relatedSystem
        "Maritz",
        "Hubspot",
        "Data warehouse",
        "Passport",
        "Exhibitor Space Application (linked at major category)" ;

    amtmeta:nextReviewDate      "2026-06-01"^^xsd:date ;
    amtmeta:nextReviewNote      "Need to discuss for Space Application." ;

    amtmeta:relatedDocumentation <https://amtonline.sharepoint.com/sites/governance/Shared%20Documents/Taxonomy%20Change%20Process.docx> ;

    amtmeta:releaseDate     "2026-05-26"^^xsd:date ;
    amtmeta:scopeSummary    "v0.1.1 -- add pc:ProductCategory marker individual as the amtmeta:codesFor target for visitor_pc_codeset and exhibitor_pc_codeset. No taxonomy content change; just an anchor for the CodeSet vocabularies introduced alongside this release. Initial release (v0.1.0) was the manufacturing product categories class taxonomy." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.1.1" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.1> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.1> ;

    amtmeta:useCase
        "Marketing uses this for targeted marketing",
        "Passport uses this as a filter to create lists",
        "IMTS uses this as a demographic field for visitor registration",
        "IMTS uses this in post-show reporting",
        "IMTS uses this to create exhibitor product categories" .

#-------------------------------------------------------------------------------
# Product Category umbrella marker
#-------------------------------------------------------------------------------
# pc:ProductCategory is an amtmeta:Collection-typed marker individual
# representing "the Product Categories taxonomy as a whole" -- target of
# amtmeta:codesFor in the Product Category CodeSet vocabularies
# (visitor_pc_codeset, exhibitor_pc_codeset). It groups the eight
# top-level pc Categories (ManufacturingDevice, InfrastructureDevice,
# ProductionCell, SoftwareArtifact, ProcessAuxiliary, ServiceOffering,
# Material, Organization) via amtmeta:groups. There is no single root
# owl:Class above those eight because they are peers under different
# gufo meta-types (gufo:FunctionalComplex / gufo:EventType /
# gufo:Quantity / gufo:Agentive); the Collection grouping is the
# honest way to anchor "the whole taxonomy" without inventing a
# synthetic superclass.
# Parallels ind:Industry's role in ind_codeset (where ind:Industry is
# itself a cmns-cls:ClassificationScheme; here pc:ProductCategory is an
# amtmeta:Collection, since pc.ttl's class taxonomy isn't structured as
# Commons Classifiers).

pc:ProductCategory a owl:NamedIndividual, amtmeta:Collection ;
    rdfs:label     "Product Categories" ;
    amtmeta:groups pc:ManufacturingDevice,
                   pc:InfrastructureDevice,
                   pc:ProductionCell,
                   pc:SoftwareArtifact,
                   pc:ProcessAuxiliary,
                   pc:ServiceOffering,
                   pc:Material,
                   pc:Organization ;
    rdfs:comment   "Marker individual representing the Product Categories taxonomy as a whole. Target of amtmeta:codesFor in the Product Category CodeSet vocabularies. Typed as amtmeta:Collection (a UFO Category meta-individual) and groups the eight top-level pc Categories so it is not a structurally dangling individual." .

pc:ManufacturingDevice a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Manufacturing Device" .

pc:InfrastructureDevice a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Infrastructure Device" .

pc:ProductionCell a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Production Cell" .

pc:SoftwareArtifact a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Software Artifact" .

pc:ProcessAuxiliary a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Process Auxiliary" .

pc:ServiceOffering a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:EventType ;
    rdfs:label "Service Offering" .

pc:Material a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:Quantity ;
    rdfs:label "Material" .

pc:Organization a owl:Class, gufo:Category ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "Organization" .

